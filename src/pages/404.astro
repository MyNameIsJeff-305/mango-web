---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Page Not Found | Mango Media"
  description="The page you were looking for could not be found."
  noindex={true}
>
  <section class="relative overflow-hidden py-24 sm:py-28 lg:py-32">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"></div>
      <div class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"></div>
      <div class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"></div>
    </div>

    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="surface-panel radius-brand-xl relative overflow-hidden px-6 py-10 sm:px-8 sm:py-12 lg:px-12 lg:py-14">
          <div class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"></div>

          <p class="text-sm font-bold uppercase tracking-[0.24em] text-[rgb(var(--color-text-secondary))]">
            Error 404
          </p>

          <h1 class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl">
            This page could not be found.
          </h1>

          <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg">
            The page you are looking for may have been moved, deleted, or the link may be incorrect.
          </p>

          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="/"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Back to Home
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Explore Services
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>