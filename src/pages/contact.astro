---
import MainLayout from "../layouts/MainLayout.astro";
import Badge from "../components/ui/Badge.astro";

const contactMethods = [
  {
    title: "Email",
    value: "contact@mangomedia305.com",
    href: "mailto:contact@mangomedia305.com",
    accent: "mango",
  },
  {
    title: "Phone",
    value: "+1 (561) 583-7737",
    href: "tel:+15615837737",
    accent: "leaf",
  },
];

const serviceOptions = [
  "Website Design",
  "Local SEO",
  "Branding & Social Media Setup",
  "Online Presence Setup",
  "Google Business Profile",
  "Starter Packages",
  "Not sure yet",
];
---

<MainLayout
  title="Contact Mango Media | Let’s Build Your Online Presence"
  description="Contact Mango Media to talk about branding, websites, online presence setup, Google Business Profile optimization, or local SEO for your business."
  ogImage="/images/branding/mango-og.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div class="mx-auto max-w-4xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Let's talk about your Business</Badge>
        </div>

        <h1
          class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
        >
          Contact Mango Media
        </h1>

        <p
          class="mx-auto mt-6 max-w-3xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          Whether you need branding, a website, social media setup, or a
          stronger local presence, Mango Media is here to help you build the
          right foundation.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start lg:gap-12"
      >
        <div class="space-y-6">
          <div class="surface-panel radius-brand p-6 sm:p-8">
            <div>
              <Badge>Direct Contact</Badge>
            </div>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Tell us where you are now, and we’ll help you plan the next step.
            </h2>

            <p
              class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
            >
              Fill out the form and tell us what your business needs. Whether
              you already know the exact service or still need guidance, this is
              the best place to start.
            </p>
          </div>

          <div class="grid gap-5">
            {
              contactMethods.map((item) => (
                <article class="surface-panel radius-brand relative overflow-hidden p-6">
                  <div
                    class:list={[
                      "absolute inset-x-0 top-0 h-1.5",
                      item.accent === "mango"
                        ? "mango-gradient"
                        : "leaf-gradient",
                    ]}
                  />

                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]">
                    {item.title}
                  </p>

                  {item.href ? (
                    <a
                      href={item.href}
                      class="mt-3 inline-block font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))] transition-colors duration-200 hover:text-[rgb(var(--color-mango-pink))]"
                    >
                      {item.value}
                    </a>
                  ) : (
                    <p class="mt-3 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                      {item.value}
                    </p>
                  )}
                </article>
              ))
            }
          </div>
        </div>

        <div class="surface-panel radius-brand p-6 sm:p-8">
          <div>
            <Badge>Send us a Message</Badge>
          </div>

          <form
            name="mango-media-contact"
            method="POST"
            data-netlify="true"
            action="/thank-you"
            netlify-honeypot="bot-field"
            class="mt-6 grid gap-5"
          >
            <input type="hidden" name="form-name" value="mango-media-contact" />

            <p class="hidden">
              <label>
                Don’t fill this out if you're human:
                <input name="bot-field" />
              </label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >Name</span
                >
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                  placeholder="Your name"
                />
              </label>

              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >Business Name</span
                >
                <input
                  type="text"
                  name="business_name"
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                  placeholder="Your business name"
                />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >Email</span
                >
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                  placeholder="you@example.com"
                />
              </label>

              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >Phone</span
                >
                <input
                  type="tel"
                  name="phone"
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                  placeholder="(555) 555-5555"
                />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >Website or Social Link</span
                >
                <input
                  type="url"
                  name="website_or_social"
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                  placeholder="https://"
                />
              </label>

              <label class="grid gap-2">
                <span
                  class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                  >What do you need help with?</span
                >
                <select
                  name="service_interest"
                  class="w-full rounded-2xl border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                >
                  {
                    serviceOptions.map((option) => (
                      <option value={option}>{option}</option>
                    ))
                  }
                </select>
              </label>
            </div>

            <label class="grid gap-2">
              <span
                class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
                >Message</span
              >
              <textarea
                name="message"
                rows="6"
                required
                class="w-full rounded-[1.5rem] border border-black/8 bg-white/80 px-4 py-3 text-sm text-[rgb(var(--color-text))] outline-none backdrop-blur placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-mango-pink))] dark:border-white/10 dark:bg-white/5"
                placeholder="Tell us about your business, what you need, and where you are right now."
              ></textarea>
            </label>

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
