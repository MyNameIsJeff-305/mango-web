---
import MainLayout from "../../layouts/MainLayout.astro";
import { blogPosts } from "../../data/blogPosts";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const relatedPosts = blogPosts.filter((item) => item.slug !== post.slug).slice(0, 3);
---

<MainLayout
  title={`${post.title} | Mango Media Blog`}
  description={post.excerpt}
  ogImage={post.image}
>
  <article
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div class="mx-auto max-w-4xl">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] transition-colors duration-200 hover:text-[rgb(var(--color-mango-pink))]"
        >
          ← Back to Blog
        </a>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <span
            class:list={[
              "inline-flex rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em]",
              post.accent === "mango"
                ? "bg-[rgb(var(--color-mango-pink))/0.10] text-[rgb(var(--color-mango-pink))]"
                : "bg-[rgb(var(--color-leaf-teal))/0.12] text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]",
            ]}
          >
            {post.category}
          </span>

          <span
            class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
          >
            {post.date}
          </span>

          <span
            class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
          >
            {post.readTime}
          </span>
        </div>

        <h1
          class="mt-6 max-w-4xl font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
        >
          {post.title}
        </h1>

        <p
          class="mt-6 max-w-3xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          {post.excerpt}
        </p>

        <div
          class="mt-10 overflow-hidden rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-4 shadow-card dark:border-white/10 sm:p-5"
        >
          <div
            class="overflow-hidden rounded-[1.75rem] border border-black/6 bg-[rgb(var(--color-surface-soft))] dark:border-white/8"
          >
            <img
              src={post.image}
              alt={`Placeholder image for ${post.title}`}
              class="h-full w-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>

      <div
        class="mx-auto mt-14 grid max-w-6xl gap-12 lg:grid-cols-[0.78fr_0.22fr] lg:gap-10"
      >
        <div class="space-y-8">
          {
            post.content.map((section) => (
              <section class="surface-panel radius-brand p-6 sm:p-8">
                <h2 class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                  {section.heading}
                </h2>

                <div class="mt-5 space-y-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg">
                  {section.paragraphs.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </section>
            ))
          }

          <section
            class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12"
          >
            <div
              class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"
            >
            </div>

            <h2
              class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Want help applying this to your business?
            </h2>
            <p
              class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
            >
              Mango Media helps local businesses turn ideas like these into
              stronger branding, better websites, clearer setup, and stronger
              local visibility.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="/contact"
                class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
              >
                Get a Free Consultation
              </a>
              <a
                href="/services"
                class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
              >
                Explore Services
              </a>
            </div>
          </section>
        </div>

        <aside class="space-y-5">
          <div class="surface-panel radius-brand p-6">
            <p
              class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
            >
              Category
            </p>
            <p
              class="mt-3 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]"
            >
              {post.category}
            </p>
          </div>

          <div class="surface-panel radius-brand p-6">
            <p
              class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
            >
              Read time
            </p>
            <p
              class="mt-3 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]"
            >
              {post.readTime}
            </p>
          </div>

          <div class="surface-panel radius-brand p-6">
            <p
              class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
            >
              More from the blog
            </p>

            <div class="mt-5 space-y-4">
              {
                relatedPosts.map((item) => (
                  <a
                    href={`/blog/${item.slug}`}
                    class="block rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-4 transition-colors duration-200 hover:bg-white dark:hover:bg-white/8"
                  >
                    <p class="font-nunito text-lg font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                      {item.title}
                    </p>
                    <p class="mt-2 text-sm leading-6 text-[rgb(var(--color-text-secondary))]">
                      {item.category}
                    </p>
                  </a>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</MainLayout>
