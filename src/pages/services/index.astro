---
import MainLayout from "../../layouts/MainLayout.astro";

import { services, process, faqs } from "../../data/servicesPageData";

import WebsiteDesignIcon from "../../components/icons/WebsiteDesignIcon.astro";
import LocalSEOIcon from "../../components/icons/LocalSEOIcon.astro";
import BrandingIcon from "../../components/icons/BrandingIcon.astro";
import GBusinessServiceIcon from "../../components/icons/GBusinessService.astro";
import OnlinePresenceIcon from "../../components/icons/OnlinePresence.astro";
import StarterPackageIcon from "../../components/icons/StarterPackage.astro";
import Badge from "../../components/ui/Badge.astro";
---

<MainLayout
  title="Services | Mango Media Branding, Websites, Online Presence Setup & Local SEO"
  description="Explore Mango Media services for branding, website design, online presence setup, Google Business Profile optimization, and local SEO for local businesses."
  ogImage="/images/og-placeholder.jpg"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div class="mx-auto max-w-4xl text-center">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
        >
          <span class="inline-flex h-2.5 w-2.5 rounded-full mango-gradient"
          ></span>
          Services designed for local business growth
        </div>
        <h1
          class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
        >
          Services that help your business look stronger online
        </h1>

        <p
          class="mx-auto mt-6 max-w-3xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          From branding and setup to websites and local SEO, Mango Media helps
          local businesses build an online presence that looks polished, feels
          consistent, and supports real growth.
        </p>

        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
          >
            Book a Free Consultation
          </a>
          <a
            href="#service-list"
            class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          >
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="service-list" class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
          services.map((service) => (
            <article class="surface-panel radius-brand group relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  service.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div class="flex items-start justify-between gap-4">
                <div
                  class:list={[
                    "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-sm font-black shadow-soft",
                    service.accent === "mango"
                      ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                      : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                  ]}
                >
                  {service.title === "Website Design" && (
                    <WebsiteDesignIcon class="h-8 w-8" />
                  )}
                  {service.title === "Local SEO" && (
                    <LocalSEOIcon class="h-8 w-8" />
                  )}
                  {service.title === "Branding & Social Media Setup" && (
                    <BrandingIcon class="h-8 w-8" />
                  )}
                  {service.title === "Online Presence Setup" && (
                    <OnlinePresenceIcon class="h-8 w-8" />
                  )}
                  {service.title === "Google Business Profile Setup" && (
                    <GBusinessServiceIcon class="h-8 w-8" />
                  )}
                  {service.title === "Starter Packages" && (
                    <StarterPackageIcon class="h-8 w-8" />
                  )}
                </div>
              </div>

              <h2 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {service.title}
              </h2>

              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {service.description}
              </p>

              <ul class="mt-5 space-y-3">
                {service.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]">
                    <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                      ✓
                    </span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>

              <a
                href={service.href}
                class="mt-6 inline-flex items-center gap-2 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] transition-colors duration-200 hover:text-[rgb(var(--color-mango-pink))]"
              >
                Learn More
                <span class="transition-transform duration-200 group-hover:translate-x-1">
                  →
                </span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-start gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
          >
            <span class="inline-flex h-2.5 w-2.5 rounded-full leaf-gradient"
            ></span>
            Not sure where to start?
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            We help you choose the right next step
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-sm"
          >
            Not every business needs everything at once. Some need a website
            first. Others need better setup, stronger branding, or help getting
            found locally. We help you focus on what matters most now.
          </p>

          <div
            class="mt-8 rounded-4xl border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              The goal is simple:
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              help your business look more credible, stay more consistent, and
              create a stronger digital foundation for growth.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            process.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6">
                <div class="absolute inset-x-0 top-0 h-1.5 mango-gradient" />

                <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                  {item.title}
                </h3>
                <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                  {item.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12"
        >
          <div>
            <div
              class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
            >
              <span class="inline-flex h-2.5 w-2.5 rounded-full mango-gradient"
              ></span>
              Featured starter option
            </div>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Start strong with Mango Start
            </h2>

            <p
              class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
            >
              Mango Start is ideal for new or very small businesses that need a
              professional online presence without the stress of figuring
              everything out alone.
            </p>

            <ul class="mt-6 grid gap-3 sm:grid-cols-2">
              <li
                class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]"
              >
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]"
                  >✓</span
                >
                <span>Google Business Profile setup or claim</span>
              </li>
              <li
                class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]"
              >
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]"
                  >✓</span
                >
                <span>Facebook and Instagram setup</span>
              </li>
              <li
                class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]"
              >
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]"
                  >✓</span
                >
                <span>Basic logo or refinement of existing logo</span>
              </li>
              <li
                class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]"
              >
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]"
                  >✓</span
                >
                <span>Organized access and next-step recommendations</span>
              </li>
            </ul>
          </div>

          <div
            class="rounded-[2rem] bg-[linear-gradient(135deg,rgba(218,60,120,0.30),rgba(254,205,76,0.34),rgba(1,155,144,0.30))] p-6 sm:p-8"
          >
            <p
              class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--color-text-secondary))]"
            >
              Price range
            </p>
            <p
              class="mt-3 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))]"
            >
              $650 – $950
            </p>
            <p
              class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              Estimated delivery time: 5 to 7 business days. Great for
              businesses that need a strong launch foundation fast.
            </p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href="/services/starter-packages"
                class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
              >
                See Package Details
              </a>
              <a
                href="/contact"
                class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
              >
                Get Started
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:gap-12"
      >
        <div class="max-w-xl">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about our services
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media works and how to think
            about the right service for your business.
          </p>
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Not sure where to start? Let’s talk.
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Mango Media can help you identify the most useful service, package,
            or first step based on your business goals and current online
            presence.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Get a Free Consultation
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
