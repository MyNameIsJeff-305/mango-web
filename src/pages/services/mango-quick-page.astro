              class="absolute left-[-4rem] top-[-4rem] h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.16),rgba(254,205,76,0.10),transparent_70%)] blur-3xl"
            >
            </div>
            <div
              class="absolute bottom-[-5rem] right-[-4rem] h-80 w-80 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.10),transparent_70%)] blur-3xl"
            >
            </div>
          </div>

          <div class="relative z-10 mx-auto max-w-3xl">
            <div class="inline-flex items-center">
              <Badge>Ready to launch?</Badge>
            </div>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
            >
              Give your business one link that is easy to share and easy to
              trust.
            </h2>

            <p
              class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
            >
              Start with a Mango Quick Page today and upgrade later into a full
