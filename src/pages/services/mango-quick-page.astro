---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import MangoPagePreview from "../../components/react/MangoPagePreview";
import { demoCafe } from "../../components/data/mangoPages/demoCafe";

const pageTitle = "Mango Quick Page | Simple Business Pages by Mango Media 305";
const pageDescription =
  "Mango Quick Page gives small businesses a beautiful mobile-first business page with contact info, map, social links, QR code, and optional custom domain setup.";

const standardFeatures = [
  "Link hosted on Mango Pages",
  "Fast setup",
  "Mobile-first page design",
  "Business name, logo, and short description",
  "Contact buttons",
  "Google Maps section",
  "Social media links",
  "Business hours",
  "QR code included",
];

const proFeatures = [
  "Everything in Mango Page Standard",
  "Custom domain connection",
  "DNS configuration",
  "Optional professional email setup",
  "Stronger basic SEO setup",
  "Better page title and meta description",
  "Local business structure",
  "More polished CTA strategy",
  "Priority setup support",
];

const benefits = [
  {
    title: "Ready to share anywhere",
    description:
      "Use your Mango Quick Page on business cards, flyers, Instagram bios, WhatsApp messages, Google Business Profile, and QR codes.",
    accent: "mango",
  },
  {
    title: "Built mobile-first",
    description:
      "Most customers open links from their phones. Your page is designed to look clean, fast, and easy to use on mobile.",
    accent: "leaf",
  },
  {
    title: "Simple but professional",
    description:
      "It gives your business a more trustworthy digital presence without needing a full website right away.",
    accent: "mango",
  },
];

const pageSections = [
  "Business overview",
  "Call, text, email, or WhatsApp buttons",
  "Services or key offers",
  "Hours and location",
  "Google Maps section",
  "Social media links",
  "QR code for easy sharing",
  "Powered by Mango Media 305 footer",
];

const useCases = [
  "Restaurants, food trucks, and cafés",
  "Beauty professionals and barbers",
  "Home service businesses",
  "Auto services and mobile mechanics",
  "Local contractors",
  "Fitness trainers and instructors",
  "Event vendors and creators",
  "New businesses without a website yet",
];

const process = [
  {
    step: "01",
    title: "Send your business info",
    description:
      "Share your logo, business name, contact info, location, social links, services, and preferred style.",
  },
  {
    step: "02",
    title: "We build your Quick Page",
    description:
      "Mango Media creates a clean mobile-first page with your most important business details organized clearly.",
  },
  {
    step: "03",
    title: "You review and approve",
    description:
      "We make final adjustments so the page feels aligned with your brand and ready to share.",
  },
  {
    step: "04",
    title: "Launch and share",
    description:
      "You receive your page link and QR code so you can start sharing your business everywhere.",
  },
];

const faqs = [
  {
    question: "Is Mango Quick Page a full website?",
    answer:
      "No. Mango Quick Page is a simple business page designed to give your business one beautiful link with your essential information. If you need a full website, Mango Media can help you upgrade later.",
  },
  {
    question: "Can I use my own domain?",
    answer:
      "Yes. The Mango Page Pro package includes custom domain connection and DNS configuration.",
  },
  {
    question: "Can you create a QR code for my page?",
    answer:
      "Yes. Every Mango Quick Page includes a QR code that you can use on business cards, signs, flyers, menus, or social media.",
  },
  {
    question: "Can I add my Instagram, Facebook, TikTok, or Google profile?",
    answer:
      "Yes. Your page can include social media links, Google Business Profile links, and other important platforms your customers use.",
  },
  {
    question: "Can I upgrade later to a full website?",
    answer:
      "Yes. Mango Quick Page is a great starting point. When you are ready, Mango Media can expand your online presence into a complete website, SEO setup, and branding package.",
  },
];
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden py-20 sm:py-24 lg:py-28">
    <div class="pointer-events-none absolute inset-0 -z-10 hero-glow"></div>

    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute left-[5%] top-16 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.14),transparent_65%)] blur-3xl"
      >
      </div>
      <div
        class="absolute right-[4%] top-32 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.16),transparent_65%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.12),transparent_65%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center xl:gap-16"
      >
        <div>
          <div class="inline-flex items-center">
            <Badge>Simple business pages powered by Mango Media 305</Badge>
          </div>

          <h1
            class="mt-6 max-w-4xl font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
          >
            Your business info,
            <span
              class="bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] bg-clip-text text-transparent"
            >
              ready to share
            </span>
            in one beautiful link.
          </h1>

          <p
            class="mt-6 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Mango Quick Page gives small businesses a clean mobile-first page
            with contact buttons, location, social links, services, business
            hours, and a QR code — without needing a full website right away.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-7 py-4 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Request a Mango Quick Page
            </a>

            <a
              href="#packages"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-7 py-4 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              View Packages
            </a>
          </div>
        </div>

        <!-- Hero visual mockup -->
        <div class="relative">
          <div
            class="absolute -right-2 -top-5 z-20 hidden rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-4 py-2 font-nunito text-xs font-black uppercase tracking-[0.14em] text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.24)] sm:inline-flex"
          >
            pages.mangomedia305.com/your-business
          </div>

          <div class="relative hidden lg:block">
            <div
              class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
            >
            </div>

            <div
              class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
            >
            </div>

            <div
              class="relative w-[32rem] overflow-hidden rounded-[2rem] animate-float-scale"
            >
              <img
                src="/images/hero/hero-image-5.webp"
                alt="Mango Pages Mockup"
                class="h-full w-full object-cover"
                loading="eager"
              />
            </div>
          </div>
          <!-- End hero mockup -->
        </div>
      </div>
    </div>

    <MangoPagePreview
      business={demoCafe}
      client:load
      title="Preview a Mango Quick Page in real time."
      description="Switch between mobile, tablet, and desktop to see how your business page could look across devices."
    />

    <!-- Benefits -->
    <section class="relative py-20 sm:py-24">
      <div class="container-shell">
        <div class="mx-auto max-w-3xl text-center">
          <div class="inline-flex items-center">
            <Badge>Why Mango Quick Page?</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            A simple digital presence that helps people contact you faster.
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Mango Quick Page is built for small businesses that need a clean,
            useful, and shareable page without overcomplicating the launch.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {
            benefits.map((benefit) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    benefit.accent === "mango"
                      ? "mango-gradient"
                      : "leaf-gradient",
                  ]}
                />

                <div class="pointer-events-none absolute inset-0 overflow-hidden">
                  <div
                    class:list={[
                      "absolute right-[-3rem] top-[-3rem] h-36 w-36 rounded-full blur-3xl",
                      benefit.accent === "mango"
                        ? "bg-[radial-gradient(circle,rgba(218,60,120,0.18),rgba(254,205,76,0.12),transparent_70%)]"
                        : "bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.12),transparent_70%)]",
                    ]}
                  />
                </div>

                <div
                  class:list={[
                    "relative z-10 flex h-12 w-12 items-center justify-center rounded-2xl font-nunito text-lg font-black",
                    benefit.accent === "mango"
                      ? "mango-gradient text-white"
                      : "leaf-gradient text-[#0f1115]",
                  ]}
                >
                  ✓
                </div>

                <h3 class="relative z-10 mt-5 font-nunito text-2xl font-extrabold text-[rgb(var(--color-text))]">
                  {benefit.title}
                </h3>

                <p class="relative z-10 mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                  {benefit.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- What is included -->
    <section class="relative py-20 sm:py-24">
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div
          class="absolute left-[4%] top-10 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.10),transparent_64%)] blur-3xl"
        >
        </div>
        <div
          class="absolute right-[5%] bottom-8 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(176,241,34,0.12),transparent_62%)] blur-3xl"
        >
        </div>
      </div>

      <div class="container-shell">
        <div
          class="surface-panel radius-brand-xl grid gap-10 overflow-hidden p-6 sm:p-8 lg:grid-cols-[0.9fr_1.1fr] lg:p-10"
        >
          <div>
            <Badge>What your page can include</Badge>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Everything customers need to take the next step.
            </h2>

            <p
              class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
            >
              Your Mango Quick Page organizes your essential business
              information into one clean, mobile-friendly experience.
            </p>

            <div
              class="mt-7 rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-5"
            >
              <p
                class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
              >
                Best used for
              </p>
              <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text))]">
                Social media bios, Google Business Profile, business cards,
                flyers, vehicle decals, QR menus, appointment reminders, and
                customer follow-ups.
              </p>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            {
              pageSections.map((item) => (
                <div class="flex items-start gap-3 rounded-[1.25rem] border border-subtle bg-[rgb(var(--color-surface-soft))] p-4">
                  <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full leaf-gradient text-xs font-black text-[#0f1115]">
                    ✓
                  </span>
                  <p class="text-sm font-semibold leading-6 text-[rgb(var(--color-text))]">
                    {item}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Packages -->
    <section id="packages" class="relative py-20 sm:py-24 lg:py-28">
      <div class="container-shell">
        <div class="mx-auto max-w-3xl text-center">
          <div class="inline-flex items-center">
            <Badge>Choose your Mango Page</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Two simple options depending on how professional you want to go.
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Start with a Mango Pages link, or upgrade to a custom domain with a
            stronger setup.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          <!-- Standard -->
          <article
            class="surface-panel radius-brand relative flex h-full flex-col overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1 sm:p-8"
          >
            <div class="absolute inset-x-0 top-0 h-1.5 mango-gradient"></div>

            <div class="pointer-events-none absolute inset-0 overflow-hidden">
              <div
                class="absolute right-[-3rem] top-[-3rem] h-40 w-40 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.18),rgba(254,205,76,0.12),transparent_70%)] blur-3xl"
              >
              </div>
            </div>

            <div class="relative z-10">
              <span
                class="inline-flex rounded-full bg-[rgb(var(--color-mango-pink)/0.10)] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-mango-pink))]"
              >
                Fast Launch
              </span>

              <h3
                class="mt-5 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))]"
              >
                Mango Page Standard
              </h3>

              <p
                class="mt-4 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
              >
                A simple, beautiful business page hosted on Mango Pages, perfect
                for sharing your business information quickly.
              </p>

              <div
                class="mt-6 rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-5"
              >
                <p
                  class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
                >
                  Link example
                </p>
                <p
                  class="mt-2 break-words font-nunito text-lg font-extrabold text-[rgb(var(--color-text))]"
                >
                  pages.mangomedia305.com/your-business
                </p>
              </div>

              <ul class="mt-7 space-y-3">
                {
                  standardFeatures.map((feature) => (
                    <li class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]">
                      <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full mango-gradient text-[10px] font-black text-white">
                        ✓
                      </span>
                      <span>{feature}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="relative z-10 mt-8">
              <a
                href="/contact"
                class="inline-flex w-full items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
              >
                Request Standard
              </a>
            </div>
          </article>

          <!-- Pro -->
          <article
            class="surface-panel radius-brand relative flex h-full flex-col overflow-hidden border-transparent p-6 shadow-[0_28px_80px_rgba(1,155,144,0.18)] transition-transform duration-300 hover:-translate-y-1 sm:p-8"
          >
            <div class="absolute inset-x-0 top-0 h-1.5 leaf-gradient"></div>

            <div class="pointer-events-none absolute inset-0 overflow-hidden">
              <div
                class="absolute right-[-3rem] top-[-3rem] h-44 w-44 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.18),rgba(176,241,34,0.12),transparent_70%)] blur-3xl"
              >
              </div>
            </div>

            <div class="relative z-10">
              <div class="flex flex-wrap items-center gap-3">
                <span
                  class="inline-flex rounded-full bg-[rgb(var(--color-leaf-teal)/0.12)] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]"
                >
                  More Professional
                </span>

                <span
                  class="rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-[#0f1115]"
                >
                  Recommended
                </span>
              </div>

              <h3
                class="mt-5 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))]"
              >
                Mango Page Pro
              </h3>

              <p
                class="mt-4 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
              >
                Everything in Standard, plus a custom domain connection, DNS
                setup, optional professional email, and a stronger basic SEO
                foundation.
              </p>

              <div
                class="mt-6 rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-5"
              >
                <p
                  class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
                >
                  Domain example
                </p>
                <p
                  class="mt-2 break-words font-nunito text-lg font-extrabold text-[rgb(var(--color-text))]"
                >
                  yourbusiness.com
                </p>
              </div>

              <ul class="mt-7 space-y-3">
                {
                  proFeatures.map((feature) => (
                    <li class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]">
                      <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                        ✓
                      </span>
                      <span>{feature}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="relative z-10 mt-8">
              <a
                href="/contact"
                class="inline-flex w-full items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
              >
                Request Pro
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Use cases -->
    <section class="relative py-20 sm:py-24">
      <div class="container-shell">
        <div
          class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start xl:gap-14"
        >
          <div>
            <Badge>Who it is for</Badge>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Perfect for local businesses that need a quick professional start.
            </h2>

            <p
              class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
            >
              Mango Quick Page is especially useful for businesses that rely on
              calls, messages, social media, directions, appointments, or
              walk-ins.
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            {
              useCases.map((item) => (
                <div class="surface-panel radius-brand flex items-center gap-3 p-4">
                  <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full mango-gradient font-nunito text-sm font-black text-white">
                    M
                  </span>
                  <p class="text-sm font-bold text-[rgb(var(--color-text))]">
                    {item}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="relative py-20 sm:py-24">
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div
          class="absolute left-[4%] top-10 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.12),transparent_64%)] blur-3xl"
        >
        </div>
        <div
          class="absolute right-[5%] bottom-8 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.12),transparent_62%)] blur-3xl"
        >
        </div>
      </div>

      <div class="container-shell">
        <div class="mx-auto max-w-3xl text-center">
          <div class="inline-flex items-center">
            <Badge>How it works</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            From business info to shareable link.
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            The process is simple, fast, and designed to help you launch without
            overthinking every detail.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-4">
          {
            process.map((item) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6">
                <div class="absolute inset-x-0 top-0 h-1.5 leaf-gradient" />

                <p class="font-nunito text-4xl font-black text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]">
                  {item.step}
                </p>

                <h3 class="mt-5 font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]">
                  {item.title}
                </h3>

                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                  {item.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="relative py-20 sm:py-24">
      <div class="container-shell">
        <div
          class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start xl:gap-14"
        >
          <div>
            <Badge>FAQ</Badge>

            <h2
              class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
            >
              Questions before launching your Mango Quick Page?
            </h2>

            <p
              class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
            >
              Here are the most common things business owners ask before getting
              started.
            </p>
          </div>

          <div class="space-y-4">
            {
              faqs.map((faq) => (
                <details class="surface-panel radius-brand group overflow-hidden p-5">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                    <h3 class="font-nunito text-lg font-extrabold text-[rgb(var(--color-text))]">
                      {faq.question}
                    </h3>

                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] font-nunito text-lg font-black text-[rgb(var(--color-text))] transition-transform duration-200 group-open:rotate-45">
                      +
                    </span>
                  </summary>

                  <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                    {faq.answer}
                  </p>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="relative overflow-hidden py-20 sm:py-24 lg:py-28">
      <div class="container-shell">
        <div
          class="surface-panel radius-brand-xl relative overflow-hidden p-8 text-center sm:p-10 lg:p-14"
        >
          <div class="pointer-events-none absolute inset-0 -z-0">
