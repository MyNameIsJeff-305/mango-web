---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";

import ShieldTrustIcon from "../../components/icons/ShieldTrustIcon.astro";
import CommunicationIcon from "../../components/icons/CommunicationIcon.astro";
import LeadsIcon from "../../components/icons/LeadsIcon.astro";
import ResponsiveIcon from "../../components/icons/ResponsiveIcon.astro";

const includedItems = [
  "Strategic page structure",
  "Custom design aligned with your brand",
  "Mobile-friendly layouts",
  "Conversion-focused calls to action",
  "Clear service messaging",
  "Contact and lead flow setup",
  "Placeholder imagery where needed",
  "Basic on-page SEO setup",
];

const benefits = [
  {
    title: "Look more credible",
    description:
      "A polished website helps your business feel more established and trustworthy from the very first visit.",
    accent: "mango",
  },
  {
    title: "Communicate clearly",
    description:
      "Strong structure and messaging make it easier for visitors to understand what you do and why they should choose you.",
    accent: "leaf",
  },
  {
    title: "Support more leads",
    description:
      "Better calls to action and cleaner user flow help turn more visitors into real inquiries.",
    accent: "mango",
  },
  {
    title: "Work better on every screen",
    description:
      "A responsive experience helps your website feel clean, usable, and consistent across desktop, tablet, and mobile.",
    accent: "leaf",
  },
];

const process = [
  {
    step: "01",
    title: "Discover",
    description:
      "We learn about your business, audience, services, and goals so the website has the right strategy from the start.",
  },
  {
    step: "02",
    title: "Plan",
    description:
      "We define the content flow, page structure, and messaging direction that will make your website clearer and stronger.",
  },
  {
    step: "03",
    title: "Design",
    description:
      "We create a polished visual direction that aligns with your brand and gives visitors a stronger first impression.",
  },
  {
    step: "04",
    title: "Launch",
    description:
      "We refine the final details and deliver a website foundation that helps your business look ready to grow.",
  },
];

const faqs = [
  {
    question: "Do I need to provide all the content before we start?",
    answer:
      "Not necessarily. You may already have some content, and where needed we can help structure the messaging so the website feels clearer and more complete.",
  },
  {
    question:
      "Can you redesign an existing website instead of starting from scratch?",
    answer:
      "Yes. If your current website has useful content or structure, we can improve and redesign it instead of rebuilding everything from zero.",
  },
  {
    question: "Will the website work on mobile devices?",
    answer:
      "Yes. Mobile-friendly design is a core part of the process so your website feels clean and usable across different screen sizes.",
  },
  {
    question: "Is SEO included in website design?",
    answer:
      "We include basic on-page SEO setup and structure, but deeper local SEO work can also be supported through our dedicated Local SEO service.",
  },
];
---

<MainLayout
  title="Website Design for Local Businesses | Mango Media"
  description="Custom website design for local businesses that want to look professional, build trust, and turn visitors into real leads."
  ogImage="/images/branding/mango-og.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10"
      >
        <div class="max-w-2xl">
          <div>
            <Badge>Website Design Services</Badge>
          </div>

          <h1
            class="mt-6 max-w-xl font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl sm:leading-[1.05] lg:text-6xl"
          >
            Website design for local businesses that want to grow
          </h1>

          <p
            class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Your website should do more than exist. It should help people
            understand your business, trust your brand, and take action with
            confidence.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Request Website Design
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Back to Services
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div
            class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
          >
          </div>
          <div
            class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] animate-float-scale"
          >
            <img
              src="/images/branding/websites-hero-image.webp"
              alt="Mango Media hero image representing website design services for local businesses"
              class="h-[90%] w-[90%] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div>
            <Badge>Why website design matters</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            An outdated or unclear website can hold your business back
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            If your website feels incomplete, inconsistent, hard to navigate, or
            not aligned with your brand, it may be costing you trust, clarity,
            and real opportunities.
          </p>

          <div
            class="mt-8 rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              A stronger website helps your business feel more ready.
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              It creates a better first impression, communicates your services
              more clearly, and gives visitors a smoother path to contacting
              you.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            includedItems.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    index % 2 === 0 ? "mango-gradient" : "leaf-gradient",
                  ]}
                />
                <div class="flex items-start gap-3 text-sm font-semibold leading-7 text-[rgb(var(--color-text))] sm:text-[0.95rem]">
                  <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Outcomes that matter</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What a better website can do for your business
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {
          benefits.map((benefit) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  benefit.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  benefit.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {benefit.title === "Look more credible" && (
                  <ShieldTrustIcon class="h-8 w-8" />
                )}
                {benefit.title === "Communicate clearly" && (
                  <CommunicationIcon class="h-7 w-7" />
                )}
                {benefit.title === "Support more leads" && (
                  <LeadsIcon class="h-7 w-7" />
                )}
                {benefit.title === "Work better on every screen" && (
                  <ResponsiveIcon class="h-7 w-7" />
                )}
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {benefit.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {benefit.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>How the process works</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          A simple process from idea to polished website
        </h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-4">
        {
          process.map((item) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div class="absolute inset-x-0 top-0 h-1.5 mango-gradient" />
              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="flex flex-col gap-y-12">
        <div>
          <h2
            class="font-nunito text-3xl font-extrabold text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about our services
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media works and how to think
            about the right service for your business.
          </p>
          <img
            src="/images/branding/mango-question.webp"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-120 -translate-x-1/2 -translate-y-1/2 animate-float-soft opacity-20 sm:block md:w-150 lg:w-150"
          />
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Ready for a website that helps your business feel stronger online?
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Let’s build a website that helps your business look more credible,
            communicate more clearly, and turn more visitors into real leads.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Request Website Design
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
