---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";

import LocalDiscoveryIcon from "../../components/icons/LocalDiscoveryIcon.astro";
import MapVisibilityIcon from "../../components/icons/MapVisibilityIcon.astro";
import BuildingTrustIcon from "../../components/icons/BuildingTrustIcon.astro";
import SupportMoreLeadsIcon from "../../components/icons/SupportMoreLeads.astro";

const includedItems = [
  "Local SEO audit and visibility review",
  "Business information consistency check",
  "Google Business Profile support",
  "On-page local keyword optimization guidance",
  "Local content recommendations",
  "Location relevance improvements",
  "Foundational search visibility strategy",
  "Clear next-step recommendations",
];

const benefits = [
  {
    title: "Increase local discovery",
    description:
      "Help more nearby customers find your business when they search for the services you offer in your area.",
    accent: "leaf",
  },
  {
    title: "Strengthen map visibility",
    description:
      "A stronger local foundation can improve how your business appears in map-based and location-focused searches.",
    accent: "mango",
  },
  {
    title: "Build more trust",
    description:
      "Consistent information and a stronger local presence make your business feel more legitimate and reliable online.",
    accent: "leaf",
  },
  {
    title: "Support more leads",
    description:
      "Better visibility means more opportunities for customers to discover your business and reach out when they need help.",
    accent: "mango",
  },
];

const process = [
  {
    step: "01",
    title: "Review",
    description:
      "We assess your current local presence, business information, and visibility opportunities.",
  },
  {
    step: "02",
    title: "Identify",
    description:
      "We find the gaps, inconsistencies, and local search opportunities that matter most for your business.",
  },
  {
    step: "03",
    title: "Optimize",
    description:
      "We improve the foundation of your local visibility through better structure, relevance, and consistency.",
  },
  {
    step: "04",
    title: "Strengthen",
    description:
      "We leave you with a clearer local SEO direction that helps your business become easier to find over time.",
  },
];

const faqs = [
  {
    question: "What is local SEO?",
    answer:
      "Local SEO helps your business appear more clearly in searches made by people looking for services in a specific area, especially when they are searching nearby or using location-based terms.",
  },
  {
    question: "Do I need local SEO if I already have a website?",
    answer:
      "Yes. A website alone does not guarantee visibility. Local SEO helps your site, profiles, and business information work together more effectively for local search discovery.",
  },
  {
    question: "Is Google Business Profile part of local SEO?",
    answer:
      "Yes. Your Google Business Profile is one of the most important parts of a local SEO foundation, which is why it is often part of the strategy.",
  },
  {
    question: "How long does local SEO take to show results?",
    answer:
      "Local SEO usually improves over time rather than instantly. The goal is to build a stronger foundation that supports better visibility and more local discovery over the long term.",
  },
];
---

<MainLayout
  title="Local SEO Services for Small Businesses | Mango Media"
  description="Local SEO services that help small businesses improve visibility, show up in local searches, and attract more nearby customers."
  ogImage="/images/branding/mango-seo.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10"
      >
        <div class="max-w-2xl">
          <div>
            <Badge>Local SEO Services</Badge>
          </div>

          <h1
            class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
          >
            Local SEO that helps customers find your business
          </h1>

          <p
            class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Being great at what you do is not enough if people cannot find you.
            Local SEO helps your business appear where nearby customers are
            already searching.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Improve My Local Visibility
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Back to Services
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div
            class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
          >
          </div>
          <div
            class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] animate-float-scale"
          >
            <img
              src="/images/branding/mango-seo.webp"
              alt="Placeholder preview representing Mango Media local SEO services"
              class="h-[90%] w-[90%] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div>
            <Badge>Why SEO Matters?</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            If you are not showing up locally, you are missing real
            opportunities
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Many great businesses lose visibility simply because their local
            online presence is weak, inconsistent, or not properly structured.
            Local SEO helps correct that foundation.
          </p>

          <div
            class="mt-8 rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              Better visibility creates more chances to be chosen.
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              When your business appears more clearly in local search, you
              create more opportunities for nearby customers to discover, trust,
              and contact you.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            includedItems.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                  ]}
                />
                <div class="flex items-start gap-3 text-sm font-semibold leading-7 text-[rgb(var(--color-text))] sm:text-[0.95rem]">
                  <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class=" mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Outcomes that matter</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What stronger local SEO can do for your business
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {
          benefits.map((benefit) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  benefit.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  benefit.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {benefit.title === "Increase local discovery" && (
                  <LocalDiscoveryIcon class="h-8 w-8" />
                )}
                {benefit.title === "Strengthen map visibility" && (
                  <MapVisibilityIcon class="h-8 w-8" />
                )}
                {benefit.title === "Build more trust" && (
                  <BuildingTrustIcon class="h-8 w-8" />
                )}
                {benefit.title === "Support more leads" && (
                  <SupportMoreLeadsIcon class="h-7 w-7" />
                )}
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {benefit.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {benefit.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>How the process works</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          A simple process to strengthen your local visibility
        </h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-4">
        {
          process.map((item, index) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                ]}
              />
              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="flex flex-col gap-y-12">
        <div>
          <h2
            class="font-nunito text-3xl font-extrabold text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about local SEO
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media approaches local
            visibility and search optimization for growing businesses.
          </p>
          <img
            src="/images/branding/mango-question.webp"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-120 -translate-x-1/2 -translate-y-1/2 animate-float-soft opacity-20 sm:block md:w-150 lg:w-150"
          />
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(1,155,144,0.10),rgba(176,241,34,0.14),rgba(218,60,120,0.08))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Ready to make your business easier to find locally?
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Let’s build a stronger local SEO foundation that helps your business
            appear more clearly, feel more trustworthy, and create more
            opportunities for discovery.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Improve My Local Visibility
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
