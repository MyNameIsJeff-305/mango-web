---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";

import StrongFoundationIcon from "../../components/icons/StrongFoundationIcon.astro";
import InconsistencyIcon from "../../components/icons/InconsistencyIcon.astro";
import TimeSavingIcon from "../../components/icons/TimeSavingIcon.astro";
import FutureGrowth from "../../components/icons/FutureGrowth.astro";

const includedItems = [
  "Profile setup support across key platforms",
  "Business information standardization",
  "Access and credential organization",
  "Foundational branding alignment",
  "Key channel setup and review",
  "Bio and business description refinement",
  "Basic profile visual consistency",
  "Simple recommendations for next steps",
];

const benefits = [
  {
    title: "Create a stronger foundation",
    description:
      "A more organized online presence helps your business look more professional and ready for growth.",
    accent: "leaf",
  },
  {
    title: "Reduce inconsistency",
    description:
      "When your business information and branding are aligned, your presence feels clearer and more trustworthy.",
    accent: "mango",
  },
  {
    title: "Save time and confusion",
    description:
      "Organized profiles, access, and digital essentials make it easier to manage your online presence moving forward.",
    accent: "leaf",
  },
  {
    title: "Prepare for future growth",
    description:
      "A stronger setup today makes future work like websites, local SEO, and content expansion much easier.",
    accent: "mango",
  },
];

const process = [
  {
    step: "01",
    title: "Assess",
    description:
      "We review your current online presence, digital assets, and the main gaps affecting consistency and clarity.",
  },
  {
    step: "02",
    title: "Organize",
    description:
      "We bring your business information, branding basics, access, and platform setup into a more structured foundation.",
  },
  {
    step: "03",
    title: "Align",
    description:
      "We help your profiles and essential business details feel more connected, polished, and ready to represent your brand.",
  },
  {
    step: "04",
    title: "Deliver",
    description:
      "You receive a cleaner online setup that makes future growth and day-to-day management easier.",
  },
];

const faqs = [
  {
    question: "What is online presence setup?",
    answer:
      "It is the process of organizing and improving the essential parts of your online presence so your business looks more consistent, polished, and ready to grow.",
  },
  {
    question: "How is this different from branding or website design?",
    answer:
      "Branding focuses more on visual identity, and website design focuses on your site. Online Presence Setup focuses on the broader digital foundation that connects your business information, profiles, and key essentials.",
  },
  {
    question: "Is this a good service for a new business?",
    answer:
      "Yes. It is especially useful for new or growing businesses that need their digital basics organized before investing further in marketing or expansion.",
  },
  {
    question: "Can you help if I already have some platforms set up?",
    answer:
      "Yes. We can refine and organize what already exists so your business looks more consistent and easier to manage.",
  },
];
---

<MainLayout
  title="Online Presence Setup for Local Businesses | Mango Media"
  description="Online presence setup for businesses that need a stronger digital foundation, better consistency, and a more polished online presence."
  ogImage="/images/branding/mango-og.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10"
      >
        <div class="max-w-2xl">
          <div>
            <Badge>Online Presence Setup</Badge>
          </div>

          <h1
            class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
          >
            Online presence setup for businesses that need a stronger foundation
          </h1>

          <p
            class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            When your business information, branding, and platforms are
            disconnected, growth becomes harder. We help organize the essentials
            so your online presence works together.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Set Up My Online Presence
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Back to Services
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div
            class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
          >
          </div>
          <div
            class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] animate-float-scale"
          >
            <img
              src="/images/branding/mango-online-presence.webp"
              alt="Placeholder preview representing Mango Media online presence setup services"
              class="h-[90%] w-[90%] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div>
            <Badge>Why online presence matters</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            A scattered digital presence can make your business harder to trust
            and harder to grow
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            When your profiles, information, visuals, and access are
            inconsistent, your business can feel less prepared online. A
            stronger setup creates more clarity for both you and your audience.
          </p>

          <div
            class="mt-8 rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              A better setup makes everything easier to build from.
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              It helps your business look more polished today while making
              future efforts like websites, SEO, content, and growth more
              effective later.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            includedItems.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                  ]}
                />
                <div class="flex items-start gap-3 text-sm font-semibold leading-7 text-[rgb(var(--color-text))] sm:text-[0.95rem]">
                  <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Outcomes that matter</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What stronger setup can do for your business
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {
          benefits.map((benefit) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  benefit.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  benefit.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {benefit.title === "Create a stronger foundation" && (
                  <StrongFoundationIcon class="h-6 w-6" />
                )}
                {benefit.title === "Reduce inconsistency" && (
                  <InconsistencyIcon class="h-7 w-7" />
                )}
                {benefit.title === "Save time and confusion" && (
                  <TimeSavingIcon class="h-6 w-6" />
                )}
                {benefit.title === "Prepare for future growth" && (
                  <FutureGrowth class="h-6 w-6" />
                )}
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {benefit.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {benefit.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>How the process works</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          A simple process to organize your online foundation
        </h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-4">
        {
          process.map((item, index) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                ]}
              />
              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="flex flex-col gap-y-12">
        <div>
          <h2
            class="font-nunito text-3xl font-extrabold text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about online presence setup
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media approaches setup and
            digital organization for growing businesses.
          </p>
          <img
            src="/images/branding/mango-question.webp"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-120 -translate-x-1/2 -translate-y-1/2 animate-float-soft opacity-20 sm:block md:w-150 lg:w-150"
          />
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(1,155,144,0.10),rgba(176,241,34,0.14),rgba(218,60,120,0.08))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Ready to make your business feel more organized and more
            professional online?
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Let’s build a cleaner digital foundation that helps your business
            look stronger now and grow more easily later.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Set Up My Online Presence
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
