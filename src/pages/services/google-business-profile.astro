---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";

import GetFoundEasily from "../../components/icons/GetFoundEasily.astro";
import ShieldTrustIcon from "../../components/icons/ShieldTrustIcon.astro";
import SearchVisibilityIcon from "../../components/icons/SearchVisibilityIcon.astro";
import SupportMoreInquiries from "../../components/icons/SupportMoreInquiries.astro";

const includedItems = [
  "Google Business Profile claim or setup support",
  "Profile completion and optimization",
  "Business Profile Verification Assistance",
  "Business description optimization",
  "NAP consistency alignment and support",
  "Photo and visual recommendations",
  "Foundational local visibility support",
  "Clear next-step recommendations",
];

const benefits = [
  {
    title: "Get found more easily",
    description:
      "A stronger Google Business Profile helps your business appear more clearly when nearby customers search for the services you offer.",
    accent: "leaf",
  },
  {
    title: "Improve local trust",
    description:
      "A complete and professional-looking profile makes your business feel more legitimate and easier to choose.",
    accent: "mango",
  },
  {
    title: "Strengthen search visibility",
    description:
      "A better profile supports stronger local presence in map-based and service-related searches.",
    accent: "leaf",
  },
  {
    title: "Support more inquiries",
    description:
      "A clearer profile gives customers more confidence to call, visit, or contact your business directly.",
    accent: "mango",
  },
];

const process = [
  {
    step: "01",
    title: "Claim",
    description:
      "We help claim or set up your Google Business Profile so the business is properly connected to your brand and location.",
  },
  {
    step: "02",
    title: "Complete",
    description:
      "We organize the essential profile details that help your business appear more polished, relevant, and trustworthy.",
  },
  {
    step: "03",
    title: "Optimize",
    description:
      "We improve the description, categories, and core structure so your profile supports stronger local visibility.",
  },
  {
    step: "04",
    title: "Strengthen",
    description:
      "You receive a cleaner, more useful profile foundation that better supports local discovery and future growth.",
  },
];

const faqs = [
  {
    question: "Why is Google Business Profile so important?",
    answer:
      "It is one of the most important tools for local visibility because it helps your business appear in Google Maps and local search results when nearby customers are looking for services like yours.",
  },
  {
    question: "Can you help if I have not claimed my profile yet?",
    answer:
      "Yes. This service can help with claiming, setting up, and organizing the profile so your business has a stronger starting point.",
  },
  {
    question: "What if my profile already exists?",
    answer:
      "We can still help improve and optimize the existing profile so it feels more complete, more relevant, and more aligned with your brand.",
  },
  {
    question: "Is Google Business Profile the same as local SEO?",
    answer:
      "It is a major part of local SEO, but not the full picture. A stronger Google Business Profile works best when it is supported by a broader local presence strategy.",
  },
];
---

<MainLayout
  title="Google Business Profile Setup and Optimization | Mango Media"
  description="Google Business Profile setup and optimization that helps local businesses get found, build trust, and improve local visibility."
  ogImage="/images/branding/mango-gmb.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10"
      >
        <div class="max-w-2xl">
          <div>
            <Badge>Google Business Profile Optimization</Badge>
          </div>

          <h1
            class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
          >
            Google Business Profile setup that helps your business get found
          </h1>

          <p
            class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Your Google Business Profile is one of the most important assets for
            local visibility. We help you claim, set up, optimize, and
            strengthen it so your business appears more clearly online.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Optimize My Google Profile
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Back to Services
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div
            class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
          >
          </div>
          <div
            class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] animate-float-scale"
          >
            <img
              src="/images/branding/mango-gmb.webp"
              alt="Placeholder preview representing Mango Media Google Business Profile services"
              class="h-[90%] w-[90%] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div>
            <Badge>Why Google Business Profile matters?</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            A weak or incomplete profile can make your business harder to
            discover and harder to trust
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Many local businesses miss opportunities simply because their Google
            Business Profile is incomplete, inconsistent, or not properly
            optimized. A stronger profile helps fix that gap.
          </p>

          <div
            class="mt-8 rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              A stronger profile creates more chances to be seen and chosen.
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              It helps nearby customers understand what you do, trust your
              business more quickly, and take action when they need your
              services.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            includedItems.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                  ]}
                />
                <div class="flex items-start gap-3 text-sm font-semibold leading-7 text-[rgb(var(--color-text))] sm:text-[0.95rem]">
                  <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Outcomes that matter</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What a stronger Google Business Profile can do for your business
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {
          benefits.map((benefit) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  benefit.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  benefit.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {benefit.title === "Get found more easily" && (
                  <GetFoundEasily class="h-8 w-8" />
                )}
                {benefit.title === "Improve local trust" && (
                  <ShieldTrustIcon class="h-8 w-8" />
                )}
                {benefit.title === "Strengthen search visibility" && (
                  <SearchVisibilityIcon class="h-8 w-8" />
                )}
                {benefit.title === "Support more inquiries" && (
                  <SupportMoreInquiries class="h-8 w-8" />
                )}
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {benefit.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {benefit.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>How the process works</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          A simple process to strengthen your local profile presence
        </h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-4">
        {
          process.map((item, index) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  index % 2 === 0 ? "leaf-gradient" : "mango-gradient",
                ]}
              />
              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="flex flex-col gap-y-12">
        <div>
          <h2
            class="font-nunito text-3xl font-extrabold text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about Google Business Profile setup
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media approaches profile setup
            and local visibility support for growing businesses.
          </p>
          <img
            src="/images/branding/mango-question.webp"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-120 -translate-x-1/2 -translate-y-1/2 animate-float-soft opacity-20 sm:block md:w-150 lg:w-150"
          />
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(1,155,144,0.10),rgba(176,241,34,0.14),rgba(218,60,120,0.08))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Ready to strengthen one of the most important local visibility
            assets your business has?
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Let’s build a stronger Google Business Profile foundation that helps
            your business get found more clearly, feel more trustworthy, and
            create more local opportunities.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)] transition-transform duration-200 hover:-translate-y-0.5"
            >
              Optimize My Google Profile
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
