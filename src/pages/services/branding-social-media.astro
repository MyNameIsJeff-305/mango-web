---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/ui/Badge.astro";

import StrongFirstImpressionIcon from "../../components/icons/StrongFirstImpression.astro";
import BrandConsistencyIcon from "../../components/icons/BrandConsistency.astro";
import BetterSocialCredibilityIcon from "../../components/icons/BetterSocialCredibilityIcon.astro";
import EasierContentCreationIcon from "../../components/icons/EasierContentCreationIcon.astro";

const includedItems = [
  "Basic brand direction and visual consistency",
  "Logo refinement or simple logo creation",
  "Base color palette selection",
  "Typography selection",
  "Facebook setup",
  "Instagram setup",
  "Bio and description optimization",
  "Profile and cover image setup",
];

const benefits = [
  {
    title: "Stronger first impressions",
    description:
      "A clearer visual identity helps your business feel more polished and trustworthy from the moment someone finds you online.",
    accent: "mango",
  },
  {
    title: "More consistent branding",
    description:
      "When your colors, typography, logo, and profiles feel aligned, your business looks more intentional and established.",
    accent: "leaf",
  },
  {
    title: "Better social credibility",
    description:
      "A complete, professional setup makes your social profiles feel more real, active, and ready for customers to engage with.",
    accent: "mango",
  },
  {
    title: "Easier future content creation",
    description:
      "With the right visual foundation in place, posting and growing your online presence becomes much easier over time.",
    accent: "leaf",
  },
];

const process = [
  {
    step: "01",
    title: "Discover",
    description:
      "We learn about your business, audience, style, and current online presence so the brand direction feels aligned from the start.",
  },
  {
    step: "02",
    title: "Define",
    description:
      "We shape the visual basics that help your brand feel cleaner, more consistent, and more recognizable online.",
  },
  {
    step: "03",
    title: "Set Up",
    description:
      "We organize and optimize your main social profiles so they feel more polished, complete, and ready to represent your business.",
  },
  {
    step: "04",
    title: "Launch",
    description:
      "You receive a stronger branded foundation that makes your business look more professional and easier to grow from.",
  },
];

const faqs = [
  {
    question: "Do I need to already have a logo?",
    answer:
      "No. If you do not have a logo yet, we can create a simple one or help refine an existing direction so your business has a cleaner starting point.",
  },
  {
    question: "Is this the same as social media management?",
    answer:
      "No. This service focuses on setup, visual consistency, and profile optimization rather than ongoing posting or monthly content management.",
  },
  {
    question: "Can you help if I already have social profiles?",
    answer:
      "Yes. We can improve, refine, and optimize the profiles you already have so they look more polished and aligned with your brand.",
  },
  {
    question: "What platforms are included?",
    answer:
      "This service is primarily focused on Facebook and Instagram setup, but the same brand foundation can help support your wider online presence as well.",
  },
];
---

<MainLayout
  title="Branding and Social Media Setup for Small Businesses | Mango Media"
  description="Branding and social media setup that helps small businesses look more polished, consistent, and ready to grow online."
  ogImage="/images/branding/mango-branding.webp"
>
  <section
    class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
  >
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-8%] top-12 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.34),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.22),transparent_60%)] blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.14),transparent_62%)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10"
      >
        <div class="max-w-2xl">
          <div>
            <Badge>Branding and Social Media Setup</Badge>
          </div>

          <h1
            class="mt-6 font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl lg:text-6xl"
          >
            Branding and social media setup that makes your business look ready
          </h1>

          <p
            class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            A professional online presence starts with consistency. We help
            shape the look, feel, and profile setup that makes your business
            appear more polished and trustworthy.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Build My Brand Presence
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              Back to Services
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div
            class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
          >
          </div>
          <div
            class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] animate-float-scale"
          >
              <img
                src="/images/branding/mango-branding.webp"
                alt="Placeholder preview representing Mango Media branding and social media setup services"
                class="h-[90%] w-[90%] object-cover"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
      >
        <div class="max-w-xl">
          <div>
            <Badge>Why branding and social media matters</Badge>
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            An inconsistent brand presence can make a good business look
            unprepared
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            When your profiles, colors, visuals, and messaging feel
            disconnected, your business can look less credible than it really
            is. A stronger brand setup helps fix that first impression.
          </p>

          <div
            class="mt-8 rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              Consistency helps your business feel more real and more memorable.
            </p>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          {
            includedItems.map((item, index) => (
              <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
                <div
                  class:list={[
                    "absolute inset-x-0 top-0 h-1.5",
                    index % 2 === 0 ? "mango-gradient" : "leaf-gradient",
                  ]}
                />
                <div class="flex items-start gap-3 text-sm font-semibold leading-7 text-[rgb(var(--color-text))] sm:text-[0.95rem]">
                  <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>Outcomes that matter</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What stronger branding and setup can do for your business
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {
          benefits.map((benefit) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  benefit.accent === "mango"
                    ? "mango-gradient"
                    : "leaf-gradient",
                ]}
              />

              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  benefit.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {benefit.title === "Stronger first impressions" && (
                  <StrongFirstImpressionIcon class="h-6 w-6" />
                )}
                {benefit.title === "More consistent branding" && (
                  <BrandConsistencyIcon class="h-6 w-6" />
                )}
                {benefit.title === "Better social credibility" && (
                  <BetterSocialCredibilityIcon class="h-6 w-6" />
                )}
                {benefit.title === "Easier future content creation" && (
                  <EasierContentCreationIcon class="h-6 w-6" />
                )}
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {benefit.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {benefit.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2">
          <Badge>How the process works</Badge>
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          A simple path to a more polished brand presence
        </h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-4">
        {
          process.map((item, index) => (
            <article class="surface-panel radius-brand relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  index % 2 === 0 ? "mango-gradient" : "leaf-gradient",
                ]}
              />
              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div class="flex flex-col gap-y-12">
        <div>
          <h2
            class="font-nunito text-3xl font-extrabold text-[rgb(var(--color-text))] sm:text-4xl"
          >
            Frequently asked questions about branding and social media setup
          </h2>
          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            These answers help clarify how Mango Media approaches brand
            foundations and profile setup for growing businesses.
          </p>
          <img
            src="/images/branding/mango-question.webp"
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-120 -translate-x-1/2 -translate-y-1/2 animate-float-soft opacity-20 sm:block md:w-150 lg:w-150"
          />
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, index) => (
              <details
                class="surface-panel radius-brand group overflow-hidden p-0"
                open={index === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-nunito text-lg font-extrabold text-[rgb(var(--color-text))] marker:content-none">
                  <span>{faq.question}</span>
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-surface-soft))] text-[rgb(var(--color-text-secondary))] transition-transform duration-200 group-open:rotate-45">
                    +
                  </span>
                </summary>
                <div class="px-6 pb-6 pt-0">
                  <div class="h-px w-full bg-black/6 dark:bg-white/10" />
                  <p class="pt-5 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                    {faq.answer}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24 lg:pb-28">
    <div class="container-shell">
      <div
        class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"
        >
        </div>

        <div class="mx-auto max-w-4xl text-center">
          <h2
            class="font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Ready to make your brand feel more polished and more professional
            online?
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Let’s build a stronger visual foundation that helps your business
            look more credible, more consistent, and more ready to grow.
          </p>

          <div
            class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Build My Brand Presence
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              See Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
