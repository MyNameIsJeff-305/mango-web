---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { siteConfig } from "../config/site";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  schemaType?:
    | "Organization"
    | "LocalBusiness"
    | "Service"
    | "Article"
    | "WebPage";
  schemaData?: Record<string, unknown>;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage = siteConfig.ogImage,
  canonical,
  noindex = false,
  schemaType = "WebPage",
  schemaData = {},
} = Astro.props;

const currentUrl =
  canonical ?? new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const absoluteOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, siteConfig.siteUrl).toString();

const robots = noindex ? "noindex, nofollow" : "index, follow";

const baseOrganizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.name,
  legalName: siteConfig.legalName,
  url: siteConfig.siteUrl,
  logo: new URL("/images/logo-placeholder.png", siteConfig.siteUrl).toString(),
  image: absoluteOgImage,
  description: siteConfig.description,
  email: siteConfig.email,
  telephone: siteConfig.phone,
  sameAs: siteConfig.socialLinks,
};

const baseLocalBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: siteConfig.name,
  url: siteConfig.siteUrl,
  image: absoluteOgImage,
  email: siteConfig.email,
  telephone: siteConfig.phone,
  areaServed: siteConfig.areaServed,
  description: siteConfig.description,
  sameAs: siteConfig.socialLinks,
};

const pageSchema =
  schemaType === "Organization"
    ? { ...baseOrganizationSchema, ...schemaData }
    : schemaType === "LocalBusiness"
      ? { ...baseLocalBusinessSchema, ...schemaData }
      : schemaType === "Service"
        ? {
            "@context": "https://schema.org",
            "@type": "Service",
            provider: {
              "@type": "Organization",
              name: siteConfig.name,
              url: siteConfig.siteUrl,
            },
            areaServed: siteConfig.areaServed,
            ...schemaData,
          }
        : schemaType === "Article"
          ? {
              "@context": "https://schema.org",
              "@type": "Article",
              headline: title,
              description,
              image: absoluteOgImage,
              mainEntityOfPage: currentUrl,
              author: {
                "@type": "Organization",
                name: siteConfig.name,
              },
              publisher: {
                "@type": "Organization",
                name: siteConfig.name,
                logo: {
                  "@type": "ImageObject",
                  url: new URL(
                    "/images/logo-placeholder.png",
                    siteConfig.siteUrl,
                  ).toString(),
                },
              },
              ...schemaData,
            }
          : {
              "@context": "https://schema.org",
              "@type": "WebPage",
              name: title,
              description,
              url: currentUrl,
              ...schemaData,
            };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={currentUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:image" content={absoluteOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <meta name="theme-color" content="#f4f4f2" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        const storageKey = "mango-theme";
        const root = document.documentElement;
        const metaTheme = document.querySelector('meta[name="theme-color"]');

        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";

        const applyTheme = (theme) => {
          root.classList.remove("light", "dark");
          root.classList.add(theme);
          root.dataset.theme = theme;

          if (metaTheme) {
            metaTheme.setAttribute(
              "content",
              theme === "dark" ? "#0f1115" : "#f4f4f2",
            );
          }
        };

        try {
          const storedTheme = localStorage.getItem(storageKey);
          const initialTheme = storedTheme || getSystemTheme();
          applyTheme(initialTheme);

          window.__setPreferredTheme = (theme) => {
            localStorage.setItem(storageKey, theme);
            applyTheme(theme);
          };

          window.__getPreferredTheme = () => root.dataset.theme || initialTheme;

          window
            .matchMedia("(prefers-color-scheme: dark)")
            .addEventListener("change", (event) => {
              const stored = localStorage.getItem(storageKey);
              if (!stored) {
                applyTheme(event.matches ? "dark" : "light");
              }
            });
        } catch {
          applyTheme("light");
        }
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  </head>

  <body
    class="bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))] font-montserrat antialiased transition-colors duration-300"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-[rgb(var(--color-surface))] focus:px-4 focus:py-2 focus:text-[rgb(var(--color-text))]"
    >
      Skip to content
    </a>

    <div
      class="relative min-h-screen overflow-x-clip bg-[rgb(var(--color-bg))]"
    >
      <div
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[32rem] bg-[radial-gradient(circle_at_top_left,rgba(254,205,76,0.20),transparent_35%),radial-gradient(circle_at_top_right,rgba(176,241,34,0.14),transparent_30%),radial-gradient(circle_at_center,rgba(218,60,120,0.10),transparent_45%)]"
      >
      </div>

      <Header />

      <main id="main-content" class="relative">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
