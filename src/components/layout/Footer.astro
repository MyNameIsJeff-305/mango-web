---
const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const serviceLinks = [
  { href: "/services/website-design", label: "Website Design" },
  { href: "/services/local-seo", label: "Local SEO" },
  { href: "/services/branding-social-media", label: "Branding & Social Media" },
  { href: "/services/online-presence-setup", label: "Online Presence Setup" },
  {
    href: "/services/google-business-profile",
    label: "Google Business Profile",
  },
  { href: "/services/starter-packages", label: "Starter Packages" },
];

const socialLinks = [
  {
    href: "https://instagram.com/",
    label: "Instagram",
    icon: "instagram",
  },
  {
    href: "https://facebook.com/",
    label: "Facebook",
    icon: "facebook",
  },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="relative mt-24 border-t border-black/5 bg-[rgb(var(--color-surface))] text-[rgb(var(--color-text))] transition-colors duration-300 dark:border-white/10"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-56 bg-[radial-gradient(circle_at_top_left,rgba(218,60,120,0.12),transparent_40%),radial-gradient(circle_at_top_right,rgba(1,155,144,0.12),transparent_35%),radial-gradient(circle_at_center,rgba(254,205,76,0.10),transparent_45%)]"
  >
  </div>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <div
      class="mb-10 overflow-hidden rounded-[2rem] border border-black/5 bg-[rgb(var(--color-bg))] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.06)] dark:border-white/10 dark:shadow-[0_24px_80px_rgba(0,0,0,0.28)] sm:p-8 lg:flex lg:items-center lg:justify-between lg:gap-8"
    >
      <div class="max-w-2xl">
        <p
          class="font-montserrat text-xs font-bold uppercase tracking-[0.24em] text-[rgb(var(--color-text-secondary))]"
        >
          Ready to grow online?
        </p>
        <h2
          class="mt-3 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl"
        >
          Let’s build a stronger digital presence for your business.
        </h2>
        <p
          class="mt-4 max-w-xl text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-base"
        >
          From branding and social media setup to websites and local SEO, Mango
          Media helps local businesses look more polished, get found more
          easily, and grow with confidence.
        </p>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:shrink-0">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3 font-nunito text-sm font-extrabold text-white shadow-[0_14px_36px_rgba(218,60,120,0.28)] transition-transform duration-200 hover:-translate-y-0.5"
        >
          Get a Free Consultation
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
        >
          Explore Services
        </a>
      </div>
    </div>

    <div class="grid gap-10 lg:grid-cols-[1.4fr_0.8fr_1fr_1fr] lg:gap-8">
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-3"
          aria-label="Mango Media home"
        >
          <span
            class="relative flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] shadow-[0_12px_32px_rgba(218,60,120,0.22)] ring-1 ring-black/5 dark:ring-white/10"
          >
            <span
              class="absolute inset-[2px] rounded-[1rem] bg-[linear-gradient(160deg,rgba(255,255,255,0.22),rgba(255,255,255,0.04))]"
            ></span>
            <span
              class="relative font-nunito text-xl font-black tracking-tight text-white"
              >M</span
            >
          </span>

          <span class="flex flex-col leading-none">
            <span class="font-nunito text-xl font-extrabold tracking-tight"
              >Mango Media</span
            >
            <span
              class="font-montserrat text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
            >
              Build. Grow. Stand Out.
            </span>
          </span>
        </a>

        <p
          class="mt-5 max-w-md text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
        >
          We help local businesses build a stronger online presence through
          branding, websites, social media setup, Google Business Profile
          optimization, and local SEO.
        </p>

        <div class="mt-6 flex items-center gap-3">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noreferrer"
                aria-label={social.label}
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/8 bg-white/80 text-[rgb(var(--color-text))] transition-all duration-200 hover:-translate-y-0.5 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
              >
                {social.icon === "instagram" ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    class="h-5 w-5"
                  >
                    <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle
                      cx="17.5"
                      cy="6.5"
                      r="1"
                      fill="currentColor"
                      stroke="none"
                    />
                  </svg>
                ) : (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-5 w-5"
                  >
                    <path d="M13.5 21v-7h2.3l.4-3h-2.7V9.1c0-.9.3-1.6 1.6-1.6H16V4.9c-.2 0-.9-.1-1.8-.1-1.8 0-3.1 1.1-3.1 3.3V11H8.8v3h2.3v7h2.4Z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="font-nunito text-lg font-extrabold">Quick Links</h3>
        <ul class="mt-4 space-y-3">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-semibold text-[rgb(var(--color-text-secondary))] transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-nunito text-lg font-extrabold">Services</h3>
        <ul class="mt-4 space-y-3">
          {
            serviceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-semibold text-[rgb(var(--color-text-secondary))] transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-nunito text-lg font-extrabold">Contact</h3>
        <ul
          class="mt-4 space-y-3 text-sm font-semibold text-[rgb(var(--color-text-secondary))]"
        >
          <li>
            <a
              href="tel:+15615837737"
              class="transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
            >
              +1 (561) 583-7737
            </a>
          </li>
          <li>
            <a
              href="mailto:mangomedia305@gmail.com"
              class="transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
            >
              mangomedia305@gmail.com
            </a>
          </li>
          <li>Miami, Florida</li>
          <li class="pt-2 leading-7">
            Creative online presence solutions for local businesses that want to
            look polished, get discovered, and grow.
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-4 border-t border-black/5 pt-6 text-sm text-[rgb(var(--color-text-secondary))] dark:border-white/10 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {currentYear} Mango Media. All rights reserved.</p>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/privacy-policy"
          class="transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="transition-colors duration-200 hover:text-[rgb(var(--color-text))]"
        >
          Terms
        </a>
      </div>
    </div>
  </div>
</footer>
