---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header
  class="sticky top-0 z-50 border-b border-black/8 bg-white/95 shadow-[0_1px_0_rgba(0,0,0,0.04)] backdrop-blur-xl transition-colors duration-300 dark:border-white/10 dark:bg-[#0f1115]/75 dark:shadow-none"
>
  <div
    class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
  >
    <a
      href="/"
      class="group inline-flex shrink-0 items-center gap-3"
      aria-label="Mango Media home"
    >
      <span
        class="relative flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl"
      >
        <img
          src="/images/branding/logo-square.webp"
          alt="Mango Media logo"
          class="h-full w-full object-cover"
          loading="eager"
        />
      </span>

      <span class="flex flex-col leading-none">
        <span
          class="font-nunito text-lg font-extrabold tracking-tight text-[rgb(var(--color-text))]"
        >
          Mango Media
        </span>
        <span
          class="font-montserrat text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-black/55 dark:text-[rgb(var(--color-text-secondary))]"
        >
          Build. Grow. Stand Out.
        </span>
      </span>
    </a>

    <nav
      class="hidden items-center gap-1 rounded-full border border-black/10 bg-white px-2 py-2 shadow-[0_10px_30px_rgba(15,23,42,0.08)] lg:flex dark:border-white/10 dark:bg-white/5 dark:shadow-none"
    >
      {
        navLinks.map((link) => {
          const active = isActive(link.href);

          return (
            <a
              href={link.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "rounded-full px-4 py-2 font-nunito text-sm font-bold transition-all duration-200",
                active
                  ? "bg-[#f3f4f6] text-[rgb(var(--color-text))] shadow-sm ring-1 ring-black/8 dark:bg-white/10 dark:ring-white/10"
                  : "text-[rgb(var(--color-text-secondary))] hover:bg-[#f3f4f6] hover:text-[rgb(var(--color-text))] dark:hover:bg-white/8 dark:hover:text-white",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <button
        type="button"
        class="group inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-[rgb(var(--color-text))] shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition hover:-translate-y-0.5 hover:border-black/15 hover:bg-[#fafafa] dark:border-white/10 dark:bg-white/5 dark:text-white dark:shadow-none dark:hover:bg-white/10"
        aria-label="Toggle dark mode"
        data-theme-toggle
      >
        <span class="sr-only">Toggle dark mode</span>

        <svg
          data-theme-icon="sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="h-5 w-5 scale-100 opacity-100 transition-all duration-300 dark:scale-0 dark:opacity-0"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77"
          ></path>
        </svg>

        <svg
          data-theme-icon="moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="absolute h-5 w-5 scale-0 opacity-0 transition-all duration-300 dark:scale-100 dark:opacity-100"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>

      <a
        href="/contact"
        class="hidden rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-5 py-3 font-nunito text-sm font-extrabold text-white shadow-[0_14px_36px_rgba(218,60,120,0.28)] transition-transform duration-200 hover:-translate-y-0.5 lg:inline-flex"
      >
        Get a Free Consultation
      </a>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-[rgb(var(--color-text))] shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition hover:bg-[#fafafa] dark:border-white/10 dark:bg-white/5 dark:text-white dark:shadow-none dark:hover:bg-white/10 lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-5 w-5"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    class="border-t border-black/8 bg-white/95 px-4 py-4 backdrop-blur lg:hidden dark:border-white/10 dark:bg-[#0f1115]/95"
    data-mobile-menu
    hidden
  >
    <div class="mx-auto flex max-w-7xl flex-col gap-2 sm:px-2">
      {
        navLinks.map((link) => {
          const active = isActive(link.href);

          return (
            <a
              href={link.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "rounded-2xl px-4 py-3 font-nunito text-base font-bold transition-colors",
                active
                  ? "bg-[#f3f4f6] text-[rgb(var(--color-text))] ring-1 ring-black/8 dark:bg-white/10 dark:ring-white/10"
                  : "text-[rgb(var(--color-text-secondary))] hover:bg-[#f3f4f6] hover:text-[rgb(var(--color-text))] dark:hover:bg-white/8 dark:hover:text-white",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }

      <a
        href="/contact"
        class="mt-3 inline-flex justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-5 py-3 text-center font-nunito text-sm font-extrabold text-white shadow-[0_14px_36px_rgba(218,60,120,0.28)]"
      >
        Get a Free Consultation
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const doc = document.documentElement;
    const themeButton = document.querySelector("[data-theme-toggle]");
    const menuButton = document.querySelector("[data-mobile-menu-toggle]");
    const mobileMenu = document.querySelector("[data-mobile-menu]");

    const getStoredTheme = () => {
      const saved = localStorage.getItem("theme");
      if (saved === "light" || saved === "dark") return saved;

      if (doc.classList.contains("dark")) return "dark";
      return "light";
    };

    const applyTheme = (theme) => {
      doc.dataset.theme = theme;
      doc.classList.remove("light", "dark");
      doc.classList.add(theme);
      localStorage.setItem("theme", theme);
    };

    const getTheme = () => {
      if (doc.classList.contains("dark")) return "dark";
      return "light";
    };

    const syncThemeButton = () => {
      if (!themeButton) return;
      themeButton.setAttribute(
        "aria-label",
        getTheme() === "dark" ? "Switch to light mode" : "Switch to dark mode",
      );
    };

    applyTheme(getStoredTheme());
    syncThemeButton();

    themeButton?.addEventListener("click", () => {
      const nextTheme = getTheme() === "dark" ? "light" : "dark";

      if (typeof window.__setPreferredTheme === "function") {
        window.__setPreferredTheme(nextTheme);
      } else {
        applyTheme(nextTheme);
      }

      syncThemeButton();
    });

    const closeMenu = () => {
      if (!menuButton || !mobileMenu) return;
      menuButton.setAttribute("aria-expanded", "false");
      mobileMenu.hidden = true;
    };

    const toggleMenu = () => {
      if (!menuButton || !mobileMenu) return;
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      mobileMenu.hidden = isOpen;
    };

    menuButton?.addEventListener("click", toggleMenu);

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  })();
</script>
