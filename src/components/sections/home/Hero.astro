---
const trustPoints = [
  "Branding that feels professional",
  "Websites designed to convert",
  "Local SEO that helps you get found",
];
---

<section
  class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[-8%] top-10 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.38),transparent_65%)] blur-2xl"
    >
    </div>
    <div
      class="absolute right-[-6%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_60%)] blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.16),transparent_62%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div
      class="grid items-center gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:gap-10"
    >
      <div class="max-w-2xl">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
        >
          <span class="inline-flex h-2.5 w-2.5 rounded-full mango-gradient"
          ></span>
          Creative growth partner for local businesses
        </div>

        <h1
          class="mt-6 max-w-xl font-nunito text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-5xl sm:leading-[1.05] lg:text-6xl"
        >
          Build Your Brand.
          <span
            class="block bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_60%,#019b90_100%)] bg-clip-text text-transparent"
          >
            Grow Your Presence.
          </span>
        </h1>

        <p
          class="mt-6 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          Mango Media helps local businesses create a polished online presence
          through branding, websites, social media setup, Google Business
          Profile optimization, and local SEO strategies that help you get
          found.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
          >
            Get a Free Consultation
          </a>

          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          >
            Explore Services
          </a>
        </div>

        <p
          class="mt-6 text-sm font-medium text-[rgb(var(--color-text-secondary))]"
        >
          Built for local businesses that want to look professional, get
          discovered, and grow with confidence.
        </p>

        <ul class="mt-6 grid gap-3 sm:grid-cols-3 sm:gap-4">
          {
            trustPoints.map((point) => (
              <li class="surface-panel radius-brand flex items-start gap-3 p-4">
                <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full leaf-gradient text-[10px] font-black text-[#0f1115]">
                  ✓
                </span>
                <span class="text-sm font-semibold leading-6 text-[rgb(var(--color-text))]">
                  {point}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative">
        <div
          class="absolute -left-3 top-10 hidden h-24 w-24 rounded-[2rem] bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.22))] blur-xl sm:block"
        >
        </div>
        <div
          class="absolute -right-4 bottom-10 hidden h-28 w-28 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.24),transparent_65%)] blur-2xl sm:block"
        >
        </div>

        <div class="relative mx-auto max-w-xl">
          <div
            class="absolute inset-x-10 -top-6 h-20 rounded-full bg-[linear-gradient(135deg,rgba(218,60,120,0.18),rgba(254,205,76,0.22),rgba(1,155,144,0.16))] blur-2xl"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-4 shadow-card dark:border-white/10 sm:p-5"
          >
            <div
              class="overflow-hidden rounded-[1.75rem] border border-black/6 bg-[rgb(var(--color-surface-soft))] dark:border-white/8"
            >
              <img
                src="/images/hero-placeholder.webp"
                alt="Placeholder hero preview representing Mango Media website and branding services"
                class="h-full w-full object-cover"
                loading="eager"
              />
            </div>

            <div
              class="pointer-events-none absolute left-5 top-5 flex items-center gap-2 rounded-full border border-white/20 bg-black/30 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur"
            >
              <span class="inline-flex h-2 w-2 rounded-full bg-[#b0f122]"
              ></span>
              Online Presence Setup
            </div>
          </div>

          <div
            class="surface-panel radius-brand absolute -left-4 bottom-6 hidden max-w-[220px] p-4 sm:block lg:-left-12"
          >
            <p
              class="font-nunito text-sm font-extrabold text-[rgb(var(--color-text))]"
            >
              Professional branding, websites, and local visibility.
            </p>
            <p
              class="mt-2 text-xs leading-6 text-[rgb(var(--color-text-secondary))]"
            >
              Designed for local businesses that want a stronger first
              impression.
            </p>
          </div>

          <div
            class="surface-panel radius-brand absolute -right-3 top-10 hidden min-w-[170px] p-4 sm:block lg:-right-10"
          >
            <div
              class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
            >
              Mango Start
            </div>
            <div
              class="mt-2 font-nunito text-2xl font-extrabold text-[rgb(var(--color-text))]"
            >
              From $650
            </div>
            <div
              class="mt-1 text-xs leading-6 text-[rgb(var(--color-text-secondary))]"
            >
              Great for new businesses that need to launch strong.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
