<section class="relative py-10 sm:py-10 lg:py-10">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[8%] top-8 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.12),transparent_64%)] blur-3xl"
    >
    </div>
    <div
      class="absolute right-[6%] bottom-8 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(176,241,34,0.12),transparent_62%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div
      class="relative overflow-hidden rounded-[2.5rem] border border-black/8 bg-[rgb(var(--color-surface))] px-6 py-10 shadow-card dark:border-white/10 sm:px-8 sm:py-12 lg:px-12 lg:py-14"
    >
      <div
        class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))]"
      >
      </div>
      <div
        class="pointer-events-none absolute -right-12 top-0 h-40 w-40 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.22),transparent_62%)] blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -left-10 bottom-0 h-44 w-44 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.16),transparent_60%)] blur-3xl"
      >
      </div>

      <div
        class="grid items-center gap-10 lg:grid-cols-[1.5fr_0.95fr] lg:gap-12"
      >
        <div class="relative z-10">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
          >
            <span class="inline-flex h-2.5 w-2.5 rounded-full mango-gradient"
            ></span>
            Ready to make your business look stronger online?
          </div>

          <h2
            class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
          >
            Let’s build a digital presence that helps your business grow with
            confidence.
          </h2>

          <p
            class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
          >
            Mango Media helps local businesses look more credible, get found
            more easily, and create a stronger online foundation through
            branding, websites, setup, and local visibility strategies.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
            >
              Get a Free Consultation
            </a>

            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              View Services
            </a>
          </div>
        </div>

        <div class="pointer-events-none relative hidden min-h-[260px] lg:block">
          <div
            class="absolute right-8 top-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.24),rgba(218,60,120,0.12),transparent_72%)] blur-3xl"
          >
          </div>

          <img
            src="/images/branding/super-mango.webp"
            alt=""
            aria-hidden="true"
            class="absolute right-0 top-1/2 h-[30rem] w-[30rem] -translate-y-1/2 object-cover  opacity-[0.9] animate-float-scale drop-shadow-[0_18px_34px_rgba(0,0,0,0.14)] will-change-transform"
          />
        </div>
      </div>
