---
import Badge from "../../ui/Badge.astro";

const quickPageFeatures = [
  "Mobile-first business page",
  "Contact buttons",
  "Google Maps",
  "Social media links",
  "Business hours",
  "QR code included",
];

const tiers = [
  {
    name: "Mango Page Standard",
    badge: "Fast Launch",
    accent: "mango",
    description:
      "A simple, beautiful business page hosted on Mango Pages — perfect for sharing your info fast.",
    items: [
      "Link on Mango Pages",
      "Quick setup",
      "Mobile-first layout",
      "Contact buttons",
      "Map section",
      "Social links",
      "QR code",
    ],
  },
  {
    name: "Mango Page Pro",
    badge: "More Professional",
    accent: "leaf",
    description:
      "Everything in Standard, plus a custom domain, DNS setup, optional professional email, and stronger basic SEO.",
    items: [
      "Everything in Standard",
      "Custom domain",
      "DNS configuration",
      "Optional professional email",
      "Stronger basic SEO",
      "Better metadata setup",
      "Local business structure",
    ],
  },
];
---

<section
  id="mango-quick-page"
  class="relative overflow-hidden py-20 sm:py-24 lg:py-28"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[3%] top-12 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.12),transparent_65%)] blur-3xl"
    >
    </div>

    <div
      class="absolute right-[4%] top-1/3 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.14),transparent_65%)] blur-3xl"
    >
    </div>

    <div
      class="absolute bottom-0 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.10),transparent_66%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div
      class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center xl:gap-14"
    >
      <!-- Left content -->
      <div>
        <div class="inline-flex items-center">
          <Badge>New Mango Media service</Badge>
        </div>

        <h2
          class="mt-6 max-w-3xl font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          Mango Quick Page:
          <span
            class="bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] bg-clip-text text-transparent"
          >
            one beautiful link
          </span>
          for your business.
        </h2>

        <p
          class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          Your business info, ready to share in one beautiful link. Mango Quick
          Page gives small businesses a simple mobile-first page with contact
          info, location, social links, services, and a QR code.
        </p>

        <p
          class="mt-4 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          Perfect for businesses that need something more professional than just
          an Instagram profile, without the cost or timeline of a full website.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            quickPageFeatures.map((feature) => (
              <span class="inline-flex rounded-full border border-subtle bg-[rgb(var(--color-surface))] px-4 py-2 text-sm font-bold text-[rgb(var(--color-text-secondary))] shadow-soft">
                {feature}
              </span>
            ))
          }
        </div>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href="/services/mango-quick-page"
            class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
          >
            Explore Mango Quick Page
          </a>

          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          >
            Request a Quick Page
          </a>
        </div>
      </div>

      <!-- Right product mockup -->
      <div class="relative">
        <div
          class="absolute -right-2 -top-5 z-20 hidden rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-4 py-2 font-nunito text-xs font-black uppercase tracking-[0.14em] text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.24)] sm:inline-flex"
        >
          pages.mangomedia305.com/your-business
        </div>

        <div
          class="surface-panel radius-brand-xl relative overflow-hidden p-4 sm:p-5"
        >
          <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <div
              class="absolute right-[-4rem] top-[-4rem] h-48 w-48 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.20),rgba(218,60,120,0.12),transparent_70%)] blur-3xl"
            >
            </div>

            <div
              class="absolute bottom-[-5rem] left-[-4rem] h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.10),transparent_70%)] blur-3xl"
            >
            </div>
          </div>

          <div
            class="relative overflow-hidden rounded-[2rem] border border-subtle bg-[rgb(var(--color-surface-soft))]"
          >
            <!-- Mock page hero -->
            <div
              class="relative overflow-hidden bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_55%,#019b90_100%)] p-6 text-white sm:p-8"
            >
              <div class="absolute inset-0 bg-black/10"></div>

              <div
                class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-white/15 blur-2xl"
              >
              </div>

              <div class="relative z-10">
                <div
                  class="flex h-16 w-16 items-center justify-center rounded-[1.25rem] bg-white/20 font-nunito text-2xl font-black text-white backdrop-blur-md"
                >
                  M
                </div>

                <h3 class="mt-5 font-nunito text-3xl font-extrabold text-white">
                  Your Business Name
                </h3>

                <p class="mt-2 max-w-md text-sm leading-6 text-white/85">
                  A short description about your business, what you offer, and
                  why people should contact you.
                </p>

                <div class="mt-6 grid grid-cols-2 gap-3">
                  <a
                    href="#"
                    class="rounded-full bg-white px-4 py-3 text-center font-nunito text-sm font-extrabold text-[#0f1115]"
                  >
                    Call Now
                  </a>

                  <a
                    href="#"
                    class="rounded-full bg-[#0f1115]/85 px-4 py-3 text-center font-nunito text-sm font-extrabold text-white backdrop-blur"
                  >
                    Directions
                  </a>
                </div>
              </div>
            </div>

            <!-- Mock content -->
            <div class="space-y-4 p-5">
              <div class="grid grid-cols-3 gap-3">
                <div
                  class="rounded-[1.25rem] border border-subtle bg-[rgb(var(--color-surface))] p-3 shadow-soft"
                >
                  <p
                    class="text-[11px] font-bold uppercase tracking-[0.14em] text-[rgb(var(--color-text-secondary))]"
                  >
                    Phone
                  </p>
                  <div
                    class="mt-3 h-2.5 rounded-full bg-[rgb(var(--color-text)/0.16)]"
                  >
                  </div>
                </div>

                <div
                  class="rounded-[1.25rem] border border-subtle bg-[rgb(var(--color-surface))] p-3 shadow-soft"
                >
                  <p
                    class="text-[11px] font-bold uppercase tracking-[0.14em] text-[rgb(var(--color-text-secondary))]"
                  >
                    Hours
                  </p>
                  <div
                    class="mt-3 h-2.5 rounded-full bg-[rgb(var(--color-text)/0.16)]"
                  >
                  </div>
                </div>

                <div
                  class="rounded-[1.25rem] border border-subtle bg-[rgb(var(--color-surface))] p-3 shadow-soft"
                >
                  <p
                    class="text-[11px] font-bold uppercase tracking-[0.14em] text-[rgb(var(--color-text-secondary))]"
                  >
                    Social
                  </p>
                  <div
                    class="mt-3 h-2.5 rounded-full bg-[rgb(var(--color-text)/0.16)]"
                  >
                  </div>
                </div>
              </div>

              <div
                class="rounded-[1.5rem] border border-subtle bg-[rgb(var(--color-surface))] p-4 shadow-soft"
              >
                <div class="flex items-center justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <p
                      class="font-nunito text-base font-extrabold text-[rgb(var(--color-text))]"
                    >
                      Services
                    </p>

                    <div
                      class="mt-3 h-2.5 w-11/12 rounded-full bg-[rgb(var(--color-text)/0.14)]"
                    >
                    </div>

                    <div
                      class="mt-2 h-2.5 w-8/12 rounded-full bg-[rgb(var(--color-text)/0.10)]"
                    >
                    </div>
                  </div>

                  <div
                    class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1rem] bg-white p-2 shadow-soft"
                  >
                    <div class="grid h-full w-full grid-cols-3 gap-1">
                      <span class="rounded-sm bg-[#0f1115]"></span>
                      <span class="rounded-sm bg-slate-300"></span>
                      <span class="rounded-sm bg-[#0f1115]"></span>
                      <span class="rounded-sm bg-slate-300"></span>
                      <span class="rounded-sm bg-[#0f1115]"></span>
                      <span class="rounded-sm bg-slate-300"></span>
                      <span class="rounded-sm bg-[#0f1115]"></span>
                      <span class="rounded-sm bg-slate-300"></span>
                      <span class="rounded-sm bg-[#0f1115]"></span>
                    </div>
                  </div>
                </div>
              </div>

              <div
                class="relative h-32 overflow-hidden rounded-[1.5rem] border border-subtle bg-[rgb(var(--color-surface))] p-4 shadow-soft"
              >
                <div
                  class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(176,241,34,0.18),transparent_45%),radial-gradient(circle_at_bottom_left,rgba(1,155,144,0.16),transparent_42%)]"
                >
                </div>

                <div class="relative z-10">
                  <p
                    class="font-nunito text-base font-extrabold text-[rgb(var(--color-text))]"
                  >
                    Map Location
                  </p>

                  <div
                    class="mt-4 h-2.5 w-2/3 rounded-full bg-[rgb(var(--color-text)/0.14)]"
                  >
                  </div>

                  <div
                    class="mt-2 h-2.5 w-1/2 rounded-full bg-[rgb(var(--color-text)/0.10)]"
                  >
                  </div>
                </div>

                <div
                  class="absolute bottom-4 right-4 flex h-10 w-10 items-center justify-center rounded-full leaf-gradient font-nunito text-sm font-black text-[#0f1115]"
                >
                  ↗
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Tiers -->
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      {
        tiers.map((tier) => (
          <article class="surface-panel radius-brand relative overflow-hidden p-5 transition-transform duration-300 hover:-translate-y-1">
            <div
              class:list={[
                "absolute inset-x-0 top-0 h-1.5",
                tier.accent === "mango" ? "mango-gradient" : "leaf-gradient",
              ]}
            />

            <div class="pointer-events-none absolute inset-0 overflow-hidden">
              <div
                class:list={[
                  "absolute right-[-2.5rem] top-[-2.5rem] h-28 w-28 rounded-full blur-3xl",
                  tier.accent === "mango"
                    ? "bg-[radial-gradient(circle,rgba(218,60,120,0.18),rgba(254,205,76,0.12),transparent_70%)]"
                    : "bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.12),transparent_70%)]",
                ]}
              />
            </div>

            <div class="relative z-10">
              <span
                class:list={[
                  "inline-flex rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-[0.16em]",
                  tier.accent === "mango"
                    ? "bg-[rgb(var(--color-mango-pink)/0.10)] text-[rgb(var(--color-mango-pink))]"
                    : "bg-[rgb(var(--color-leaf-teal)/0.12)] text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]",
                ]}
              >
                {tier.badge}
              </span>

              <h3 class="mt-4 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {tier.name}
              </h3>

              <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {tier.description}
              </p>

              <ul class="mt-5 space-y-2.5">
                {tier.items.slice(0, 5).map((item) => (
                  <li class="flex items-start gap-2.5 text-sm font-medium text-[rgb(var(--color-text))]">
                    <span
                      class:list={[
                        "mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-[9px] font-black",
                        tier.accent === "mango"
                          ? "mango-gradient text-white"
                          : "leaf-gradient text-[#0f1115]",
                      ]}
                    >
                      ✓
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
