---
import Badge from "../../ui/Badge.astro";

const quickPageFeatures = [
  "Mobile-first business page",
  "Contact buttons",
  "Google Maps",
  "Social media links",
  "Business hours",
  "QR code included",
];

const tiers = [
  {
    name: "Mango Page Standard",
    badge: "Fast Launch",
    accent: "mango",
    description:
      "A simple, beautiful business page hosted on Mango Pages — perfect for sharing your info fast.",
    items: [
      "Link on Mango Pages",
      "Quick setup",
      "Mobile-first layout",
      "Contact buttons",
      "Map section",
      "Social links",
      "QR code",
    ],
  },
  {
    name: "Mango Page Pro",
    badge: "More Professional",
    accent: "leaf",
    description:
      "Everything in Standard, plus a custom domain, DNS setup, optional professional email, and stronger basic SEO.",
    items: [
      "Everything in Standard",
      "Custom domain",
      "DNS configuration",
      "Optional professional email",
      "Stronger basic SEO",
      "Better metadata setup",
      "Local business structure",
    ],
  },
];
---

<section
  id="mango-quick-page"
  class="relative overflow-hidden py-20 sm:py-24 lg:py-28"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[4%] top-10 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.10),transparent_64%)] blur-3xl"
    >
    </div>

    <div
      class="absolute right-[5%] top-1/3 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.12),transparent_62%)] blur-3xl"
    >
    </div>

    <div
      class="absolute bottom-8 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(176,241,34,0.10),transparent_62%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div
      class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center xl:gap-14"
    >
      <!-- Left content -->
      <div class="max-w-3xl lg:max-w-none">
        <div class="inline-flex items-center">
          <Badge>New Mango Media service</Badge>
        </div>

        <h2
          class="mt-6 max-w-3xl font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          Mango Quick Page:
          <span
            class="bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] bg-clip-text text-transparent"
          >
            one beautiful link
          </span>
          for your business.
        </h2>

        <p
          class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          Your business info, ready to share in one beautiful link. Mango Quick
          Page gives small businesses a simple mobile-first page with contact
          info, location, social links, services, and a QR code.
        </p>

        <p
          class="mt-4 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          Perfect for businesses that need something more professional than just
          an Instagram profile, without the cost or timeline of a full website.
        </p>

        <!-- <div class="mt-8 flex flex-wrap gap-3">
          {
            quickPageFeatures.map((feature) => (
              <span class="inline-flex rounded-full border border-subtle bg-[rgb(var(--color-surface))] px-4 py-2 text-sm font-bold text-[rgb(var(--color-text-secondary))] shadow-soft">
                {feature}
              </span>
            ))
          }
        </div> -->

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href="/services/mango-quick-page"
            class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
          >
            Explore Mango Quick Page
          </a>

          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          >
            Request a Quick Page
          </a>
        </div>
      </div>

      <!-- Right product mockup -->
      <div class="relative hidden min-w-0 lg:flex lg:justify-end">
        <div
          class="absolute right-4 top-[-1.1rem] z-20 hidden max-w-[calc(100%-2rem)] rounded-full bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] px-4 py-2 font-nunito text-xs font-black uppercase tracking-[0.14em] text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.24)] sm:inline-flex lg:-right-2 lg:-top-5"
        >
          pages.mangomedia305.com/your-business
        </div>

        <div
          class="surface-panel radius-brand-xl relative w-full overflow-hidden p-3 sm:p-5 lg:max-w-[40rem]"
        >
          <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <div
              class="absolute right-[-4rem] top-[-4rem] h-48 w-48 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.20),rgba(218,60,120,0.12),transparent_70%)] blur-3xl"
            >
            </div>

            <div
              class="absolute bottom-[-5rem] left-[-4rem] h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.10),transparent_70%)] blur-3xl"
            >
            </div>
          </div>

          <div
            class="relative mx-auto w-full max-w-[36rem] overflow-hidden rounded-[1.5rem] sm:rounded-[2rem] animate-float-scale"
          >
            <img
              src="/images/hero/hero-image-5.webp"
              alt="Mango Pages Mockup"
              class="h-auto w-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Tiers -->
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        tiers.map((tier) => (
          <article class="surface-panel radius-brand relative flex h-full flex-col overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
            <div
              class:list={[
                "absolute inset-x-0 top-0 h-1.5",
                tier.accent === "mango" ? "mango-gradient" : "leaf-gradient",
              ]}
            />

            <div class="pointer-events-none absolute inset-0 overflow-hidden">
              <div
                class:list={[
                  "absolute right-[-2.5rem] top-[-1.5rem] rounded-full blur-3xl",
                  tier.accent === "mango"
                    ? "h-32 w-32 bg-[radial-gradient(circle,rgba(218,60,120,0.18),rgba(254,205,76,0.12),transparent_70%)]"
                    : "h-36 w-36 bg-[radial-gradient(circle,rgba(1,155,144,0.16),rgba(176,241,34,0.12),transparent_70%)]",
                ]}
              />
            </div>

            <div class="relative z-10">
              <span
                class:list={[
                  "inline-flex rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em]",
                  tier.accent === "mango"
                    ? "bg-[rgb(var(--color-mango-pink)/0.10)] text-[rgb(var(--color-mango-pink))]"
                    : "bg-[rgb(var(--color-leaf-teal)/0.12)] text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]",
                ]}
              >
                {tier.badge}
              </span>

              <h3 class="mt-4 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-3xl">
                {tier.name}
              </h3>

              <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {tier.description}
              </p>
            </div>

            <ul class="relative z-10 mt-6 flex-1 space-y-3">
              {tier.items.map((item) => (
                <li class="flex items-start gap-3 text-sm font-medium text-[rgb(var(--color-text))]">
                  <span
                    class:list={[
                      "mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] font-black",
                      tier.accent === "mango"
                        ? "mango-gradient text-white"
                        : "leaf-gradient text-[#0f1115]",
                    ]}
                  >
                    ✓
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="relative z-10 mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href="/services/mango-quick-page"
                class:list={[
                  "inline-flex items-center justify-center rounded-full px-6 py-3.5 font-nunito text-sm font-extrabold transition-transform duration-200 hover:-translate-y-0.5",
                  tier.accent === "mango"
                    ? "bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] text-white shadow-mango"
                    : "bg-[linear-gradient(135deg,#019b90_0%,#b0f122_100%)] text-[#0f1115] shadow-[0_16px_40px_rgba(1,155,144,0.22)]",
                ]}
              >
                View Details
              </a>

              <a
                href="/contact"
                class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
              >
                Ask About This Plan
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
