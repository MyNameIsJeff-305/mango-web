---
import HomeServicesIcon from "../../icons/HomeServicesIcon.astro";
import BeautyAndWellnessIcon from "../../icons/BeautyAndWellnessIcon.astro";
import DentalHealthIcon from "../../icons/DentalHealthIcon.astro";
import LegalServicesIcon from "../../icons/LegalServicesIcon.astro";
import RestaurantsIcon from "../../icons/RestaurantsIcon.astro";
import RetailAndFitnessIcon from "../../icons/RetailAndFitnessIcon.astro";

import Badge from "../../ui/Badge.astro";

import { industries } from "../../../data/industries";
---

<section class="relative py-20 sm:py-24 lg:py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[4%] top-10 h-60 w-60 rounded-full bg-[radial-gradient(circle,rgba(1,155,144,0.10),transparent_64%)] blur-3xl"
    >
    </div>
    <div
      class="absolute right-[5%] bottom-6 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.10),transparent_62%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div class="mx-auto max-w-3xl text-center">
      <div
        class="inline-flex items-center"
      >
        <Badge>Built for growing local businesses</Badge>
      </div>

      <h2
        class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
      >
        Who Mango Media is built to help
      </h2>

      <p
        class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
      >
        Mango Media works especially well for service businesses, owner-led
        brands, startups, and local companies that want to look more established
        online and create a stronger digital foundation.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        industries.map((industry) => (
          <article class="surface-panel radius-brand group relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
            <div
              class:list={[
                "absolute inset-x-0 top-0 h-1.5",
                industry.accent === "mango"
                  ? "mango-gradient"
                  : "leaf-gradient",
              ]}
            />

            <div class="flex items-start justify-between gap-4">
              <div
                class:list={[
                  "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                  industry.accent === "mango"
                    ? "bg-[linear-gradient(135deg,rgba(218,60,120),rgba(254,205,76))] text-[#7f1843] dark:text-white"
                    : "bg-[linear-gradient(135deg,rgba(1,155,144),rgba(176,241,34))] text-[#0f5f58] dark:text-white",
                ]}
              >
                {industry.title === "Home Services" && (
                  <HomeServicesIcon class="h-6 w-6" />
                )}
                {industry.title === "Beauty & Wellness" && (
                  <BeautyAndWellnessIcon class="h-8 w-8" />
                )}
                {industry.title === "Dental & Healthcare" && (
                  <DentalHealthIcon class="h-7 w-7" />
                )}
                {industry.title === "Legal & Professional Services" && (
                  <LegalServicesIcon class="h-8 w-8" />
                )}
                {industry.title === "Restaurants & Hospitality" && (
                  <RestaurantsIcon class="h-7 w-7" />
                )}
                {industry.title ===
                  "Retail, Fitness & Growing Local Brands" && (
                  <RetailAndFitnessIcon class="h-8 w-8" />
                )}
              </div>
            </div>

            <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
              {industry.title}
            </h3>

            <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
              {industry.description}
            </p>
          </article>
        ))
      }
    </div>

    <div
      class="relative mt-12 overflow-hidden rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10 sm:p-8"
    >
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div
          class="absolute right-[-2rem] top-1/2 h-40 w-40 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.20),rgba(218,60,120,0.10),transparent_72%)] blur-3xl"
        >
        </div>

        <img
          src="/images/branding/strong-mango.webp"
          alt=""
          aria-hidden="true"
          class="absolute right-[-0.5rem] top-1/2 h-90 w-90 -translate-y-1/2 rotate-[8deg] opacity-[0.3] animate-pulse"
        />
      </div>

      <div class="relative z-10">
        <p
          class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--color-text-secondary))]"
        >
          Not sure if your business fits?
        </p>

        <h3
          class="mt-3 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-3xl"
        >
          If you want your business to look stronger online, <br> Mango Media can
          help.
        </h3>

        <p
          class="mt-4 mb-6 max-w-3xl text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-base"
        >
          Even if your industry is not listed here, we can help you build a
          clearer brand presence, stronger website foundation, and better local
          visibility.
        </p>

        <div
          class="relative z-10 mt-10 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:shrink-0"
        >
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
          >
            Talk About Your Business
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          >
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
