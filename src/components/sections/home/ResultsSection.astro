---
const results = [
  {
    title: "Look more credible",
    description:
      "A polished brand presence builds trust before a customer even contacts you, helping your business feel more established from the first impression.",
    accent: "mango",
  },
  {
    title: "Show up more often",
    description:
      "With stronger local SEO and profile optimization, more people can discover your business when they are actively searching for what you offer.",
    accent: "leaf",
  },
  {
    title: "Convert more visitors",
    description:
      "Clear messaging, stronger design, and better calls to action help more visitors understand your value and take the next step.",
    accent: "mango",
  },
  {
    title: "Save time",
    description:
      "An organized digital presence reduces inconsistency, confusion, and missed opportunities so your business feels easier to manage online.",
    accent: "leaf",
  },
];
---

<section class="relative py-20 sm:py-24 lg:py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[3%] top-16 h-60 w-60 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.10),transparent_64%)] blur-3xl"
    >
    </div>
    <div
      class="absolute right-[6%] bottom-8 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(176,241,34,0.12),transparent_62%)] blur-3xl"
    >
    </div>
  </div>

  <div class="container-shell">
    <div
      class="grid items-center gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-12"
    >
      <div class="max-w-xl">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-black/8 bg-white/80 px-4 py-2 text-sm font-semibold text-[rgb(var(--color-text-secondary))] shadow-soft backdrop-blur dark:border-white/10 dark:bg-white/5"
        >
          <span class="inline-flex h-2.5 w-2.5 rounded-full leaf-gradient"
          ></span>
          Real benefits for growing businesses
        </div>

        <h2
          class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl"
        >
          What a stronger online presence can do for your business
        </h2>

        <p
          class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          A better online presence is not only about appearance. It helps your
          business feel more trustworthy, become easier to find, and create
          smoother paths for customers to take action.
        </p>

        <div
          class="mt-8 overflow-hidden rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-5 shadow-card dark:border-white/10 sm:p-6"
        >
          <div
            class="rounded-[1.5rem] bg-[linear-gradient(135deg,rgba(218,60,120,0.10),rgba(254,205,76,0.14),rgba(1,155,144,0.10))] p-5"
          >
            <p
              class="font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
            >
              Stronger visibility. Better first impressions. More confidence in
              your brand.
            </p>
            <p
              class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              When your website, branding, profiles, and local visibility work
              together, your business feels more prepared to attract and convert
              real customers.
            </p>
          </div>

          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div
              class="rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-4"
            >
              <div
                class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
              >
                Built to support
              </div>
              <p
                class="mt-2 font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
              >
                Trust + growth
              </p>
            </div>

            <div
              class="rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] p-4"
            >
              <div
                class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-secondary))]"
              >
                Designed for
              </div>
              <p
                class="mt-2 font-nunito text-xl font-extrabold text-[rgb(var(--color-text))]"
              >
                Real local impact
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {
          results.map((item) => (
            <article class="surface-panel radius-brand group relative overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
              <div
                class:list={[
                  "absolute inset-x-0 top-0 h-1.5",
                  item.accent === "mango" ? "mango-gradient" : "leaf-gradient",
                ]}
              />

              <div class="flex items-start justify-between gap-4">
                <div
                  class:list={[
                    "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                    item.accent === "mango"
                      ? "bg-[linear-gradient(135deg,rgba(218,60,120,0.18),rgba(254,205,76,0.30))] text-[#7f1843] dark:text-white"
                      : "bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.28))] text-[#0f5f58] dark:text-white",
                  ]}
                >
                  {item.title.charAt(0)}
                </div>

                <span
                  class:list={[
                    "inline-flex rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em]",
                    item.accent === "mango"
                      ? "bg-[rgb(var(--color-mango-pink))/0.10] text-[rgb(var(--color-mango-pink))]"
                      : "bg-[rgb(var(--color-leaf-teal))/0.12] text-[rgb(var(--color-leaf-teal))] dark:text-[rgb(var(--color-leaf-lime))]",
                  ]}
                >
                  Benefit
                </span>
              </div>

              <h3 class="mt-5 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))]">
                {item.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-[0.95rem]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex justify-center lg:justify-start">
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
      >
        Let’s Build Your Foundation
      </a>
    </div>
  </div>
</section>
