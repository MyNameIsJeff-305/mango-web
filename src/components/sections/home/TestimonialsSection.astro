---
import Badge from "../../ui/Badge.astro";

const testimonials = [
  {
    quote:
      "Mango Media helped us turn scattered profiles and outdated visuals into a brand presence that finally felt professional and clear.",
    name: "Carlos Mendoza",
    role: "Local Business Owner",
    accent: "mango",
  },
  {
    quote:
      "The process was easy to follow, and our business immediately looked more polished online. Everything finally felt aligned.",
    name: "Ethan Walker",
    role: "Lead Software Engineer, La Nave App",
    accent: "leaf",
  },
  {
    quote:
      "They made everything feel organized, strategic, and approachable from the start. It gave us much more confidence in our online presence.",
    name: "Sofia Ramirez",
    role: "CEO, Donuts Havana",
    accent: "mango",
  },
];
---

<section class="relative py-20 sm:py-24 lg:py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-[6%] top-10 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(254,205,76,0.12),transparent_64%)] blur-3xl"></div>
    <div class="absolute right-[4%] bottom-8 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(218,60,120,0.10),transparent_62%)] blur-3xl"></div>
  </div>

  <div class="container-shell">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2">
        <Badge>True clients. True stories. True Results.</Badge>
      </div>

      <h2 class="mt-6 font-nunito text-3xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-4xl lg:text-5xl">
        What clients can expect when working with Mango Media
      </h2>

      <p class="mt-5 text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg">
        A polished result matters, but so does the experience. We focus on making the process clear, collaborative, and aligned with the real needs of growing local businesses.
      </p>
    </div>

    <div class="mt-12 grid gap-5 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <article class="surface-panel radius-brand relative flex h-full flex-col overflow-hidden p-6 transition-transform duration-300 hover:-translate-y-1">
          <div
            class:list={[
              "absolute inset-x-0 top-0 h-1.5",
              testimonial.accent === "mango" ? "mango-gradient" : "leaf-gradient",
            ]}
          ></div>

          <div class="flex items-center gap-3">
            <div
              class:list={[
                "inline-flex h-12 w-12 items-center justify-center rounded-2xl text-lg font-black shadow-soft",
                testimonial.accent === "mango"
                  ? "bg-[linear-gradient(135deg,rgba(218,60,120,0.18),rgba(254,205,76,0.30))] text-[#7f1843] dark:text-white"
                  : "bg-[linear-gradient(135deg,rgba(1,155,144,0.18),rgba(176,241,34,0.28))] text-[#0f5f58] dark:text-white",
              ]}
            >
              {testimonial.name === "Carlos Mendoza" && (
                <img
                  src="/images/client-1.webp"
                  alt="Carlos Mendoza"
                  class="h-full w-full rounded-2xl object-cover"
                />
              )}
              {testimonial.name === "Ethan Walker" && (
                <img
                  src="/images/client-2.webp"
                  alt="Ethan Walker"
                  class="h-full w-full rounded-2xl object-cover"
                />
              )}
              {testimonial.name === "Sofia Ramirez" && (
                <img
                  src="/images/client-3.webp"
                  alt="Sofia Ramirez"
                  class="h-full w-full rounded-2xl object-cover"
                />
              )}
            </div>
          </div>

          <p class="mt-6 flex-1 font-montserrat text-base leading-8 text-[rgb(var(--color-text))]">
            “{testimonial.quote}”
          </p>

          <div class="mt-6 border-t border-black/6 pt-5 dark:border-white/10">
            <p class="font-nunito text-lg font-extrabold text-[rgb(var(--color-text))]">
              {testimonial.name}
            </p>
            <p class="mt-1 text-sm font-medium text-[rgb(var(--color-text-secondary))]">
              {testimonial.role}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 overflow-hidden rounded-[2rem] border border-black/8 bg-[rgb(var(--color-surface))] p-6 shadow-card dark:border-white/10 sm:p-8 lg:flex lg:items-center lg:justify-between lg:gap-8">
      <div class="max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--color-text-secondary))]">
          Ready to become the next success story?
        </p>
        <h3 class="mt-3 font-nunito text-2xl font-extrabold tracking-tight text-[rgb(var(--color-text))] sm:text-3xl">
          Let’s create a stronger online presence your business can feel proud of.
        </h3>
        <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-secondary))] sm:text-base">
          Whether you need branding, a website, better setup, or stronger local visibility, Mango Media helps you move forward with clarity and confidence.
        </p>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:shrink-0">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-[linear-gradient(135deg,#da3c78_0%,#fecd4c_100%)] px-6 py-3.5 font-nunito text-sm font-extrabold text-white shadow-mango transition-transform duration-200 hover:-translate-y-0.5"
        >
          Let’s Create Your Success Story
        </a>
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center rounded-full border border-black/8 bg-white/80 px-6 py-3.5 font-nunito text-sm font-extrabold text-[rgb(var(--color-text))] backdrop-blur transition-colors duration-200 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
        >
          See Our Work
        </a>
      </div>
    </div>
  </div>
</section>
